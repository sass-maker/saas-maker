{
  "name": "reel-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Control-plane-friendly reel generation pipeline for SaaS Maker marketing queue items.",
  "scripts": {
    "dev": "node src/server/index.js",
    "test": "node --experimental-strip-types --test && cargo test --quiet --manifest-path reel/Cargo.toml",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-lines=20 --test-coverage-functions=25",
    "bootstrap:cloudflare": "node scripts/bootstrap-cloudflare.js",
    "probe:engines": "node scripts/probe-engines.js",
    "canary:moneyprinter": "node scripts/canary-moneyprinter-local.js",
    "moneyprinter:api": "node scripts/start-moneyprinter-api.js",
    "check:cloudflare": "node scripts/check-cloudflare-readiness.js",
    "render:accepted": "cargo run --quiet --manifest-path reel/Cargo.toml -- render-accepted --execute --repo-root .",
    "render:pro": "node scripts/render-pro.js",
    "render:html": "node scripts/export-html-composition.js",
    "render:package": "node scripts/render-content-package.js",
    "distribution": "node scripts/distribute-content-package.js",
    "marketing": "node scripts/marketing-control.js",
    "check:social": "node scripts/social-readiness.js",
    "render:reel-maker": "node scripts/render-reel-maker.js",
    "render:pro:rs": "cargo run --quiet --manifest-path reel/Cargo.toml -- render --execute --repo-root .",
    "sync:saasmaker": "node scripts/sync-from-saasmaker.js",
    "draft:signal": "node scripts/draft-from-signal.js",
    "content": "node --experimental-strip-types scripts/content-packages.js",
    "lesson:render": "node scripts/render-lesson.js",
    "smoke:lesson-local": "node scripts/smoke-lesson-local.js",
    "watch:render": "cargo run --quiet --manifest-path reel/Cargo.toml -- watch --execute --repo-root .",
    "watch:render:once": "cargo run --quiet --manifest-path reel/Cargo.toml -- watch --execute --once --repo-root .",
    "watch:render:dry": "cargo run --quiet --manifest-path reel/Cargo.toml -- watch --repo-root .",
    "validate:watcher": "node scripts/validate-watcher-parity.mjs",
    "post:ready": "cargo run --quiet --manifest-path reel/Cargo.toml -- post --execute --repo-root .",
    "sync:metrics": "cargo run --quiet --manifest-path reel/Cargo.toml -- metrics --execute --repo-root .",
    "autopilot": "node scripts/marketing-control.js tick",
    "autopilot:once": "node scripts/marketing-control.js tick",
    "autopilot:dry": "cargo run --quiet --manifest-path reel/Cargo.toml -- autopilot --repo-root .",
    "yt:bootstrap": "node scripts/youtube-oauth-bootstrap.js",
    "ig:bootstrap": "node scripts/instagram-oauth-bootstrap.js",
    "ig:refresh": "node scripts/refresh-instagram-tokens.js",
    "smoke:full": "node scripts/smoke-full-pipeline.js",
    "smoke:generation-cases": "node scripts/smoke-generation-cases.js",
    "smoke:render-modes": "node scripts/smoke-render-modes.js",
    "check:generation-readiness": "node scripts/check-generation-readiness.js",
    "ready:local": "npm run smoke:generation-cases",
    "ready:proofs": "npm run check:generation-readiness -- --refresh --strict",
    "ready:target": "npm run check:generation-readiness -- --refresh --strict --fail-unresolved",
    "smoke:artifact": "node scripts/smoke-live-artifact.js",
    "smoke:reel-maker": "node scripts/smoke-reel-maker.js",
    "smoke:mock": "node scripts/smoke-mock.js",
    "smoke:studio": "node scripts/smoke-studio.js",
    "smoke:significant-content": "node scripts/smoke-significant-content.js",
    "studio": "node scripts/studio.js",
    "faceless": "node scripts/faceless.js",
    "factory": "node scripts/factory.js",
    "significant-content": "node scripts/significant-content.js",
    "setup:kokoro": "bash scripts/setup-kokoro.sh",
    "worker:dry-run": "npx wrangler deploy --dry-run",
    "deploy": "node scripts/manual-deploy.mjs deploy.yml ci.yml"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
