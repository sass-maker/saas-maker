{
  "name": "foundry",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev:api": "pnpm -F @saas-maker/api dev",
    "dev:cockpit": "pnpm -F @saas-maker/dashboard dev",
    "dev:cockpit:local": "node scripts/dev-cockpit-local.mjs",
    "dev:cockpit:prod": "NEXT_PUBLIC_API_URL=https://api.sassmaker.com pnpm --dir apps/cockpit exec next dev --webpack --port 3001",
    "build": "pnpm build:types && pnpm build:db && pnpm build:email && pnpm build:api && pnpm build:cockpit && pnpm build:widget && pnpm build:showcase && pnpm build:docs",
    "build:types": "pnpm -F @saas-maker/shared-types build",
    "build:db": "pnpm -F @saas-maker/ops build && pnpm -F @saas-maker/db build",
    "build:email": "pnpm -F @saas-maker/ops build && pnpm -F @saas-maker/email build",
    "build:api": "pnpm -F @saas-maker/api build",
    "build:cockpit": "pnpm -F @saas-maker/dashboard build",
    "build:widget": "pnpm -F @saas-maker/feedback build",
    "build:showcase": "pnpm -F @saas-maker/sdk build && pnpm -F @saas-maker/landing-page build",
    "build:docs": "pnpm -F @saas-maker/docs build",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "check:openapi": "pnpm generate:openapi && git diff --exit-code -- packages/cli/src/openapi.json docs/openapi/openapi.json apps/docs/public/openapi.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test tests/e2e/api/",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm build:types && pnpm -F @saas-maker/ops build && pnpm -F @saas-maker/sdk build && pnpm -F @saas-maker/ui build && pnpm -F @saas-maker/email build && pnpm -r --if-present typecheck",
    "smoke": "node scripts/smoke-prod.mjs",
    "fleet:prod-smoke": "node scripts/fleet-production-smoke.mjs",
    "fleet:secret-audit": "node scripts/fleet-secret-audit.mjs",
    "fleet:monitoring-audit": "node scripts/fleet-monitoring-audit.mjs",
    "fleet:clone": "node scripts/fleet-clone.mjs",
    "fleet:cf-builds": "node scripts/fleet-audit.mjs --skip-local --skip-github --skip-dirty --skip-smoke --fail-on-failure",
    "bootstrap:cloudflare": "npm --prefix ../reel-pipeline run bootstrap:cloudflare --",
    "check:cloudflare": "npm --prefix ../reel-pipeline run check:cloudflare --",
    "smoke:artifact": "npm --prefix ../reel-pipeline run smoke:artifact --",
    "symphony": "FND_API_URL=${FND_API_URL:-https://api.sassmaker.com} node scripts/symphony-local.mjs",
    "symphony:agent-usage": "node scripts/symphony-agent-usage.mjs",
    "droid:local": "node scripts/droid-headless-local.mjs",
    "fleet:audit": "node scripts/fleet-audit.mjs",
    "symphony:runner": "node scripts/symphony-runner.mjs",
    "symphony:import-failures": "node scripts/fleet-failure-import.mjs",
    "symphony:normalize-weekly": "node scripts/fleet-weekly-normalize.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@saas-maker/eslint-config": "workspace:*",
    "@saas-maker/prettier-config": "workspace:*",
    "@saas-maker/tsconfig": "workspace:*",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "husky": "9.1.7",
    "lighthouse": "^13.3.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  },
  "prettier": "@saas-maker/prettier-config"
}
