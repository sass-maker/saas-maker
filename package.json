{
  "name": "saas-maker",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:api": "pnpm -F @saas-maker/api dev",
    "dev:cockpit": "pnpm -F @saas-maker/dashboard dev",
    "dev:cockpit:local": "node scripts/dev-cockpit-local.mjs",
    "build": "turbo run build",
    "build:api": "pnpm -F @saas-maker/api typecheck",
    "build:cockpit": "turbo run build --filter=@saas-maker/dashboard...",
    "build:widget": "pnpm -F @saas-maker/feedback build",
    "build:showcase": "pnpm -F @saas-maker/landing-page build",
    "build:docs": "pnpm -F @saas-maker/docs-blume build",
    "deploy:guard": "bash ../fleet-ops/scripts/fleet-deploy-guard.sh saas-maker",
    "deploy:directory": "pnpm deploy:guard && pnpm -F @saas-maker/landing-page deploy",
    "deploy:docs": "pnpm deploy:guard && pnpm -F @saas-maker/docs-blume deploy",
    "deploy:api": "pnpm deploy:guard && pnpm -F @saas-maker/api deploy",
    "deploy:cockpit": "pnpm deploy:guard && pnpm -F @saas-maker/dashboard deploy",
    "catalog:sync-public": "node scripts/sync-fleet-public-products.mjs",
    "catalog:check-public": "node scripts/sync-fleet-public-products.mjs --check",
    "catalog:validate-public": "node scripts/sync-fleet-public-products.mjs --validate",
    "check:docs": "node scripts/check-docs.mjs",
    "test": "vitest run tests/api/*.test.ts",
    "lint": "biome check .",
    "typecheck": "turbo run typecheck",
    "smoke": "node scripts/smoke-prod.mjs",
    "prepare": "husky",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "husky": "9.1.7",
    "turbo": "2.5.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
