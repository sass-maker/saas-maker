{
  "name": "foundry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm -F @saas-maker/api dev",
    "dev:cockpit": "pnpm -F @saas-maker/dashboard dev",
    "build:types": "pnpm -F @saas-maker/shared-types build",
    "build:db": "pnpm -F @saas-maker/db build",
    "build:api": "pnpm -F @saas-maker/api build",
    "build:cockpit": "pnpm -F @saas-maker/dashboard build",
    "build:analytics-ui": "pnpm -F @saas-maker/analytics-ui build",
    "build:badge": "pnpm -F @saas-maker/badge build",
    "build:widget": "pnpm -F @saas-maker/feedback build",
    "build:showcase": "pnpm -F @saas-maker/landing-page build",
    "build:docs": "pnpm -F @saas-maker/docs build",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "check:openapi": "pnpm generate:openapi && git diff --exit-code -- packages/cli/src/openapi.json docs/openapi/openapi.json apps/docs/public/openapi.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test tests/e2e/api/",
    "lint": "pnpm -r --if-present lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@saas-maker/eslint-config": "^1.0.1",
    "@saas-maker/prettier-config": "^1.0.0",
    "@saas-maker/tsconfig": "^1.0.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "prettier": "@saas-maker/prettier-config"
}