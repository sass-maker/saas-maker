#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLEET_OPS_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
CRON_DIR="$FLEET_OPS_DIR/automation/codex-cron"
JOBS_FILE="$CRON_DIR/jobs.tsv"
RUNNER="$SCRIPT_DIR/run-codex-cron"
BEGIN="# BEGIN FLEET OPS CODEX CRON"
END="# END FLEET OPS CODEX CRON"

usage() {
  cat <<'EOF'
usage: install-codex-cron [--remove|--print]

Installs, removes, or prints the managed Fleet Ops Codex cron block.
EOF
}

if [ ! -x "$RUNNER" ]; then
  echo "runner is not executable: $RUNNER" >&2
  exit 1
fi

managed_block="$(
  {
    echo "$BEGIN"
    echo "SHELL=/bin/zsh"
    echo "PATH=/Users/assistant/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    awk -F '\t' -v runner="$RUNNER" '
      NR == 1 { next }
      $2 == "yes" {
        printf "%s %s %s >/dev/null 2>&1\n", $3, runner, $1
      }
    ' "$JOBS_FILE"
    echo "$END"
  }
)"

current="$(mktemp "${TMPDIR:-/tmp}/fleet-cron-current.XXXXXX")"
next="$(mktemp "${TMPDIR:-/tmp}/fleet-cron-next.XXXXXX")"
trap 'rm -f "$current" "$next"' EXIT

case "${1:-}" in
  --help|-h|help) usage; exit 0 ;;
  --print) printf '%s\n' "$managed_block"; exit 0 ;;
  --remove|"") ;;
  *)
    usage >&2
    exit 2
    ;;
esac

crontab -l > "$current" 2>/dev/null || true
awk -v begin="$BEGIN" -v end="$END" '
  $0 == begin { skip=1; next }
  $0 == end { skip=0; next }
  skip != 1 { print }
' "$current" > "$next"

if [ "${1:-}" = "--remove" ]; then
  if [ -s "$next" ]; then
    crontab "$next"
  else
    crontab -r 2>/dev/null || true
  fi
  echo "removed fleet Codex cron jobs"
  exit 0
fi

if [ -s "$next" ] && [ "$(tail -c 1 "$next" | wc -l | tr -d ' ')" = "0" ]; then
  printf '\n' >> "$next"
fi

printf '%s\n' "$managed_block" >> "$next"
crontab "$next"
echo "installed fleet Codex cron jobs:"
awk -F '\t' 'NR > 1 && $2 == "yes" { printf "- %s: %s\n", $1, $3 }' "$JOBS_FILE"
