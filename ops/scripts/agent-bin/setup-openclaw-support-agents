#!/usr/bin/env bash
set -euo pipefail

FLEET_ROOT="${FLEET_ROOT:-$HOME/Desktop/fleet}"
MODEL="${OPENCLAW_SUPPORT_MODEL:-openai/gpt-5.5}"
DRY_RUN=0

SUPPORT_PROJECTS=(
  fleet-ops
  saas-maker
  free-ai
  reel-pipeline
  drank
  high-signal
  knowledge-base
  research-papers
  aliveville
  codevetter
  starboard
)

usage() {
  cat <<'EOF'
usage: setup-openclaw-support-agents [--dry-run] [project ...]

Registers Fleet support projects as isolated OpenClaw agents. With no project
arguments, registers the support and support+saas projects plus fleet-ops.

Environment:
  FLEET_ROOT              Fleet workspace path.
  OPENCLAW_SUPPORT_MODEL  Model assigned to newly-created agents.
EOF
}

log() {
  printf '%s\n' "$*"
}

exclude_openclaw_workspace_files() {
  local workspace="$1"
  local git_dir
  local git_exclude
  local prefix
  local file
  local pattern

  git_dir="$(git -C "$workspace" rev-parse --absolute-git-dir 2>/dev/null || true)"
  [[ -n "$git_dir" ]] || return 0
  git_exclude="$git_dir/info/exclude"
  prefix="$(git -C "$workspace" rev-parse --show-prefix 2>/dev/null || true)"

  run mkdir -p "$(dirname "$git_exclude")"

  for file in HEARTBEAT.md IDENTITY.md SOUL.md TOOLS.md USER.md openclaw-workspace-state.json .openclaw/ memory/; do
    pattern="${prefix}${file}"
    if [[ "$DRY_RUN" == "1" ]]; then
      log "[dry-run] ensure git exclude: $pattern"
    elif ! grep -Fxq "$pattern" "$git_exclude" 2>/dev/null; then
      printf '%s\n' "$pattern" >> "$git_exclude"
    fi
  done
}

run() {
  if [[ "$DRY_RUN" == "1" ]]; then
    printf '[dry-run]'
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  else
    "$@"
  fi
}

agent_workspace() {
  local agent="$1"
  openclaw agents list --json 2>/dev/null | node -e '
const fs = require("node:fs");
const agents = JSON.parse(fs.readFileSync(0, "utf8"));
const id = process.argv[1];
const hit = agents.find((agent) => agent.id === id);
if (hit?.workspace) console.log(hit.workspace);
' "$agent"
}

projects=()
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      projects+=("$1")
      shift
      ;;
  esac
done

if [[ "${#projects[@]}" -eq 0 ]]; then
  projects=("${SUPPORT_PROJECTS[@]}")
fi

if ! command -v openclaw >/dev/null 2>&1; then
  echo "openclaw is not installed or not on PATH" >&2
  exit 127
fi

for project in "${projects[@]}"; do
  workspace="$FLEET_ROOT/$project"
  if [[ ! -d "$workspace" ]]; then
    log "skip: missing workspace $workspace"
    continue
  fi

  exclude_openclaw_workspace_files "$workspace"

  existing="$(agent_workspace "$project")"
  if [[ -n "$existing" ]]; then
    if [[ "$existing" == "$workspace" ]]; then
      log "ok: OpenClaw agent $project -> $workspace"
    else
      log "warn: OpenClaw agent $project already points to $existing"
    fi
    continue
  fi

  log "add: OpenClaw agent $project -> $workspace"
  run openclaw agents add "$project" \
    --workspace "$workspace" \
    --model "$MODEL" \
    --non-interactive
  run openclaw agents set-identity --agent "$project" --name "Fleet: $project"
done
