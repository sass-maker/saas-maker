# =============================================================================
# SaaS Maker — Environment Variables
# =============================================================================
# Copy this to .env.local (Next.js apps) or .dev.vars (Workers API)
# NEVER commit actual values to git.

# --- Workers API (workers/api/.dev.vars) ---
AUTH_SECRET=                        # Auth.js JWE encryption key
APP_BASE_URL=https://app.sassmaker.com
CORS_ORIGIN=https://app.sassmaker.com
DATABASE_URL=                       # CockroachDB connection string
RESEND_API_KEY=                     # Resend email service key
NOTIFICATION_FROM_EMAIL=noreply@sassmaker.com
FREE_AI_BASE_URL=                   # Optional: AI proxy base URL
FREE_AI_API_KEY=                    # Optional: AI proxy API key
# HYPERDRIVE and FEEDBACK_IMAGES are Cloudflare bindings (configured in wrangler.toml)

# --- Dashboard (apps/dashboard/.env.local) ---
AUTH_SECRET=                        # Same as above
AUTH_GOOGLE_ID=                     # Google OAuth client ID
AUTH_GOOGLE_SECRET=                 # Google OAuth client secret
NEXT_PUBLIC_API_URL=https://api.sassmaker.com
NEXT_PUBLIC_SAASMAKER_API_KEY=      # Project API key for widgets
NEXT_PUBLIC_SITE_URL=https://app.sassmaker.com

# --- Landing Page (apps/landing-page/.env.local) ---
NEXT_PUBLIC_API_URL=https://api.sassmaker.com
NEXT_PUBLIC_SAASMAKER_API_KEY=      # Project API key for analytics
NEXT_PUBLIC_DASHBOARD_URL=https://app.sassmaker.com

# --- CLI (packages/cli) ---
SAASMAKER_API_URL=https://api.saasmaker.dev  # Override via env or ~/.saasmaker/config.json
