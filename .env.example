# =============================================================================
# Foundry / saas-maker — Environment Variables
# =============================================================================
# Copy to .env.local (Next.js apps) or .dev.vars (Workers API).
# NEVER commit actual values to git.

# --- Workers API (workers/api/.dev.vars) ---
# Auth: API validates better-auth opaque session tokens directly against the
# shared D1 `session` table — no shared secret is needed on the worker side.
APP_BASE_URL=https://app.sassmaker.com
CORS_ORIGIN=https://app.sassmaker.com
RESEND_API_KEY=                     # Resend email service key
NOTIFICATION_FROM_EMAIL=notifications@sassmaker.com
POSTHOG_API_KEY=                    # PostHog server ingest key (phc_*)
POSTHOG_HOST=https://us.i.posthog.com
FREE_AI_BASE_URL=                   # Optional: AI proxy base URL
FREE_AI_API_KEY=                    # Optional: AI proxy API key
# Cloudflare bindings (configured in workers/api/wrangler.toml):
#   DB                — D1 (saasmaker-db)
#   FEEDBACK_IMAGES   — R2 bucket
#   AI                — Workers AI

# --- Cockpit (apps/cockpit/.env.local) ---
BETTER_AUTH_SECRET=                 # Same value as workers AUTH_SECRET
AUTH_URL=https://app.sassmaker.com
AUTH_GOOGLE_ID=                     # Google OAuth client ID
AUTH_GOOGLE_SECRET=                 # Google OAuth client secret
NEXT_PUBLIC_API_URL=https://api.sassmaker.com
NEXT_PUBLIC_SAASMAKER_API_KEY=      # Project API key for in-app widgets
NEXT_PUBLIC_SITE_URL=https://app.sassmaker.com
POSTHOG_PERSONAL_API_KEY=           # For PostHog mission-control queries
POSTHOG_PROJECT_ID=
GH_TOKEN=                           # Optional. Cockpit auto-falls-back to `gh auth token` when unset.

# --- Showcase / landing (apps/showcase/.env.local) ---
NEXT_PUBLIC_API_URL=https://api.sassmaker.com
NEXT_PUBLIC_SAASMAKER_API_KEY=      # Project API key for analytics
NEXT_PUBLIC_DASHBOARD_URL=https://app.sassmaker.com

# --- CLI (packages/cli) ---
FND_API_URL=https://api.sassmaker.com        # Override via env or ~/.foundry/config.json
