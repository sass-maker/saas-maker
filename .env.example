# SaaS Maker API, used by future queue sync.
SAASMAKER_API_URL=https://api.sassmaker.com

# Optional local MoneyPrinterTurbo API endpoint.
MONEYPRINTER_API_URL=http://127.0.0.1:8080

# Optional artifact directory for local/mock renderer.
REEL_PIPELINE_ARTIFACT_DIR=./artifacts

# Optional public artifact sync. For local tests this can point to a static dir.
REEL_ARTIFACT_PUBLIC_DIR=./tmp/public-reels
REEL_ARTIFACT_BASE_URL=https://assets.example.com/reels
REEL_ARTIFACT_R2_BUCKET=

# Optional UGC job-spec output path for OpenShorts adapter.
OPENSHORTS_JOB_DIR=./artifacts/openshorts-jobs

# Optional posting provider. Manual is safe and never posts externally.
# Supported: manual | upload-post | youtube
REEL_POST_PROVIDER=manual
UPLOAD_POST_API_URL=https://api.upload-post.com

# Multi-account social posting: structure lives in config/social-accounts.json,
# secrets are pulled from the env vars named in clientIdEnv / refreshTokenEnv / etc.
# See docs/operations/auto-posting.md for the wiring.
SOCIAL_ACCOUNTS_CONFIG=config/social-accounts.json

# Single-account YouTube (kept for compatibility; multi-account replaces this).
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_CATEGORY_ID=22

# Per-brand YouTube credentials. Account routes are already declared in
# config/social-accounts.example.json; only these values are missing.
YT_HIGH_SIGNAL_CLIENT_ID=
YT_HIGH_SIGNAL_CLIENT_SECRET=
YT_HIGH_SIGNAL_REFRESH_TOKEN=
YT_SIGNIFICANTHOBBIES_CLIENT_ID=
YT_SIGNIFICANTHOBBIES_CLIENT_SECRET=
YT_SIGNIFICANTHOBBIES_REFRESH_TOKEN=
YT_SWE_INTERVIEW_PREP_CLIENT_ID=
YT_SWE_INTERVIEW_PREP_CLIENT_SECRET=
YT_SWE_INTERVIEW_PREP_REFRESH_TOKEN=

# Instagram Standard Access via Instagram Login flow. Bootstrap once with
# scripts/instagram-oauth-bootstrap.js, then refresh daily with
# scripts/refresh-instagram-tokens.js. See docs/operations/instagram-setup.md.
IG_APP_ID=
IG_APP_SECRET=

# Per-brand Instagram credentials.
IG_HIGH_SIGNAL_APP_ID=
IG_HIGH_SIGNAL_APP_SECRET=
IG_HIGH_SIGNAL_USER_ID=
IG_HIGH_SIGNAL_LONG_LIVED_TOKEN=
IG_SIGNIFICANTHOBBIES_APP_ID=
IG_SIGNIFICANTHOBBIES_APP_SECRET=
IG_SIGNIFICANTHOBBIES_USER_ID=
IG_SIGNIFICANTHOBBIES_LONG_LIVED_TOKEN=
IG_SWE_INTERVIEW_PREP_APP_ID=
IG_SWE_INTERVIEW_PREP_APP_SECRET=
IG_SWE_INTERVIEW_PREP_USER_ID=
IG_SWE_INTERVIEW_PREP_LONG_LIVED_TOKEN=

# Marketing control loop. Pending content and posting requests are never
# auto-approved. The minute runner only renders accepted content and releases
# separately approved, due distribution requests.
AUTOPILOT_INTERVAL_MS=60000
AUTOPILOT_LIMIT=10
PIPELINE_RENDER_CONCURRENCY=1

# Lesson pipeline: DeepSeek for script generation, ElevenLabs for voice, Pexels for b-roll.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

PEXELS_API_KEY=

# Optional override for ffmpeg / ffprobe binaries (defaults to PATH).
FFMPEG_PATH=
FFPROBE_PATH=

# Lesson library file store directory.
LESSON_PIPELINE_DIR=.reel-pipeline/lessons

# Studio LLM provider chain (first configured provider wins).
# Default order: free-ai,codex,deepseek — all optional; templates otherwise.
STUDIO_LLM_PROVIDERS=free-ai,codex,deepseek
# free-ai fleet gateway (OpenAI-compatible, free upstream providers).
FREE_AI_API_KEY=
FREE_AI_BASE_URL=https://ai-gateway.sassmaker.com
FREE_AI_MODEL=auto
FREE_AI_PROJECT_ID=reel-pipeline
# Local Codex CLI (uses your ChatGPT subscription; needs `codex` on PATH).
STUDIO_CODEX_MODEL=

# Local Kokoro TTS (npm run setup:kokoro). Used by lesson videos and the
# faceless `kokoro` engine. LESSON_TTS_PROVIDER=elevenlabs to opt out.
KOKORO_VOICE=af_heart
LESSON_TTS_PROVIDER=
