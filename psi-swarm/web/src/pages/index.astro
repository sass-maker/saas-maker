---
import '../styles/global.css';
import RunDashboard from '../components/RunDashboard.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>psi-swarm · perf swarms with p99</title>
    <meta name="description" content="Run Lighthouse N times across realistic device/network presets. See p50/p75/p90/p99 of your Web Vitals, not one noisy number." />
  </head>
  <body class="min-h-screen">
    <main class="max-w-5xl mx-auto px-6 py-10">
      <header class="mb-10 flex items-baseline justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight">
            <span class="text-[var(--color-cyan)]">psi</span>-swarm
          </h1>
          <p class="text-[var(--color-dim)] mt-1 text-sm">
            Lighthouse, run many times across realistic presets. The shape of your perf, not one noisy point.
          </p>
        </div>
        <a href="./projects/" class="text-sm text-[var(--color-dim)] hover:text-[var(--color-text)] transition">
          projects
        </a>
        <a href="./compare/" class="text-sm text-[var(--color-dim)] hover:text-[var(--color-text)] transition">
          compare
        </a>
        <a href="./watchlist/" class="text-sm text-[var(--color-dim)] hover:text-[var(--color-text)] transition">
          watchlist
        </a>
        <a href="./gallery/" class="text-sm text-[var(--color-dim)] hover:text-[var(--color-text)] transition">
          gallery
        </a>
      </header>
      <RunDashboard client:load />
    </main>
  </body>
</html>
