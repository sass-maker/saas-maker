{
  "$schema": "reel-pipeline.live-generation-readiness.v1",
  "checks": [
    {
      "id": "local-generation-cases",
      "description": "Top-level local generation matrix passed and nested reports validated.",
      "generationCases": ["marketing-render-modes", "worker-render-pro", "lesson-video", "creator-mvp"],
      "type": "report",
      "report": "tmp/generation-cases-smoke/report.json",
      "schema": "reel-pipeline.generation-cases-smoke.v1",
      "requiredForFullReadiness": true,
      "refreshable": true,
      "command": "npm run smoke:generation-cases"
    },
    {
      "id": "render-mode-matrix",
      "description": "Accepted marketing posts render through every local/no-credential render mode.",
      "generationCases": ["marketing-render-modes"],
      "type": "report",
      "report": "tmp/render-mode-smoke/report.json",
      "schema": "reel-pipeline.render-mode-smoke.v1",
      "requiredForFullReadiness": true,
      "command": "npm run smoke:render-modes"
    },
    {
      "id": "lesson-local",
      "description": "Lesson pipeline lifecycle works locally with fake adapters.",
      "generationCases": ["lesson-video"],
      "type": "report",
      "report": "tmp/lesson-local-smoke/report.json",
      "schema": "reel-pipeline.lesson-local-smoke.v1",
      "expect": [{ "path": "ok", "equals": true }],
      "requiredForFullReadiness": true,
      "command": "npm run smoke:lesson-local"
    },
    {
      "id": "manual-posting-fallback",
      "description": "Rendered marketing post can move into a manual posting handoff without setting posted_at.",
      "generationCases": ["marketing-render-modes"],
      "type": "report",
      "report": "tmp/full-pipeline-smoke/report.json",
      "schema": "reel-pipeline.full-pipeline-smoke.v1",
      "expect": [{ "path": "ok", "equals": true }],
      "requiredForFullReadiness": true,
      "refreshable": true,
      "command": "npm run smoke:full"
    },
    {
      "id": "moneyprinter-real-mp4",
      "description": "MoneyPrinterTurbo produced a real MP4 larger than 1 KB from local canary inputs.",
      "generationCases": ["marketing-render-modes"],
      "type": "report",
      "report": "tmp/moneyprinter-canary-result.json",
      "schema": "reel-pipeline.moneyprinter-canary.v1",
      "expect": [
        { "path": "ok", "equals": true },
        { "path": "outputSize", "min": 1024 }
      ],
      "requiredForFullReadiness": true,
      "refreshable": true,
      "docs": "docs/operations/runbooks/generation-readiness.md#live-render-proof",
      "command": "MONEYPRINTER_API_URL=http://127.0.0.1:18080 npm run canary:moneyprinter"
    },
    {
      "id": "reel-maker-full",
      "description": "reel-maker adapter generated at least one reviewable or ready variant.",
      "generationCases": ["marketing-render-modes"],
      "type": "report",
      "report": "tmp/reel-maker-smoke/report.json",
      "schema": "reel-pipeline.reel-maker-smoke.v1",
      "expect": [{ "path": "ok", "equals": true }],
      "requiredForFullReadiness": true,
      "refreshable": true,
      "command": "npm run smoke:reel-maker"
    },
    {
      "id": "artifact-worker-range-playback",
      "description": "Artifact Worker served health, full MP4/object fetch, and HTTP byte range playback.",
      "generationCases": ["marketing-render-modes", "worker-render-pro"],
      "type": "report",
      "report": "tmp/artifact-live-smoke/report.json",
      "schema": "reel-pipeline.artifact-live-smoke.v1",
      "expect": [
        { "path": "ok", "equals": true },
        { "path": "rangeStatus", "equals": 206 }
      ],
      "requiredForFullReadiness": true,
      "refreshable": true,
      "command": "REEL_ARTIFACT_BASE_URL=https://reel-pipeline-artifacts.sarthakagrawal927.workers.dev REEL_ARTIFACT_SMOKE_KEY=fixture-real-render.mp4 npm run smoke:artifact"
    },
    {
      "id": "render-pro-syntax",
      "description": "Production render-pro script parses before live approved-reel runs.",
      "generationCases": ["worker-render-pro"],
      "type": "command",
      "command": "node",
      "args": ["--check", "scripts/render-pro.js"],
      "requiredForFullReadiness": true
    },
    {
      "id": "render-pro-live-proof",
      "description": "Production render-pro has been run against a real approved Worker reel id on the target host.",
      "generationCases": ["worker-render-pro"],
      "type": "manual",
      "requiredForFullReadiness": false,
      "docs": "docs/operations/runbooks/target-host-readiness.md#render-pro-live-proof",
      "command": "npm run render:pro -- <approved-reel-id>; confirm Worker record has render metadata and R2 serves the MP4."
    },
    {
      "id": "lesson-live-prereqs",
      "description": "Live lesson rendering has the required API keys available in the environment.",
      "generationCases": ["lesson-video"],
      "type": "env",
      "env": ["DEEPSEEK_API_KEY", "ELEVENLABS_API_KEY", "ELEVENLABS_VOICE_ID", "PEXELS_API_KEY"],
      "requiredForFullReadiness": false,
      "docs": "docs/operations/runbooks/target-host-readiness.md#lesson-live-prereqs",
      "command": "npm run lesson:render -- --input test/fixtures/lessons/closures.json --auto-approve"
    },
    {
      "id": "social-posting-prereqs",
      "description": "Auto posting has enough OAuth material to attempt YouTube and Instagram provider flows.",
      "generationCases": ["marketing-render-modes"],
      "type": "envAnyGroup",
      "groups": [
        ["YOUTUBE_OAUTH_CLIENT_ID", "YOUTUBE_OAUTH_CLIENT_SECRET", "YOUTUBE_OAUTH_REFRESH_TOKEN"],
        ["IG_APP_ID", "IG_APP_SECRET"]
      ],
      "requiredForFullReadiness": false,
      "docs": "docs/operations/runbooks/target-host-readiness.md#social-posting-prereqs",
      "command": "npm run post:ready -- --posting-provider auto --limit 1"
    },
    {
      "id": "creator-mvp-reviewed",
      "description": "Manual kids-story videos are intentionally outside software automation; packets must be produced and reviewed by a creator.",
      "generationCases": ["creator-mvp"],
      "type": "manual",
      "requiredForFullReadiness": false,
      "docs": "docs/operations/runbooks/target-host-readiness.md#creator-mvp-reviewed",
      "command": "Use docs/product/creator-mvp.md and docs/product/creator-mvp-packs/ before adding automation."
    }
  ]
}
