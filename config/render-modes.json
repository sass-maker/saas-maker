{
  "$schema": "reel-pipeline.render-modes.v1",
  "modes": [
    {
      "id": "mock",
      "provider": "mock",
      "surface": "render-accepted",
      "category": "local",
      "description": "No-dependency placeholder renderer for tests and dry runs.",
      "smoke": { "type": "renderAccepted" }
    },
    {
      "id": "html-composition",
      "aliases": ["html", "web-composition"],
      "provider": "html-composition",
      "surface": "render-accepted",
      "category": "local",
      "description": "Exports HTML/CSS preview artifacts, timeline JSON, and word-level captions.",
      "smoke": { "type": "renderAccepted" }
    },
    {
      "id": "ascii",
      "aliases": ["ascii-animation", "ascii-fable", "askai"],
      "provider": "ascii-animation",
      "surface": "render-accepted",
      "category": "local",
      "description": "Generates stylized ASCII/pixel interlude MP4s with local tools.",
      "smoke": { "type": "renderAccepted" }
    },
    {
      "id": "grok-video",
      "aliases": ["grok", "grok-videos"],
      "provider": "grok-video",
      "surface": "render-accepted",
      "category": "local-asset",
      "description": "Copies approved local Grok/Imagine MP4 exports into the standard artifact flow.",
      "smoke": { "type": "grokFixture" }
    },
    {
      "id": "reel-maker",
      "aliases": ["remotion"],
      "provider": "reel-maker",
      "surface": "render-accepted",
      "category": "local-remotion",
      "description": "Remotion/product-proof adapter behind the VideoBrief contract.",
      "smoke": {
        "type": "renderAccepted",
        "env": { "REEL_MAKER_SKIP_REMOTION": "1" },
        "note": "Remotion skipped; adapter/orchestrator path verified."
      }
    },
    {
      "id": "moneyprinterturbo",
      "aliases": ["stock"],
      "provider": "moneyprinterturbo",
      "surface": "render-accepted",
      "category": "service",
      "description": "Default stock-footage MP4 renderer through a running MoneyPrinterTurbo API.",
      "smoke": {
        "type": "service",
        "urlEnv": "MONEYPRINTER_API_URL",
        "defaultUrl": "http://127.0.0.1:8080",
        "path": "/docs",
        "hint": "Start MoneyPrinterTurbo, then run npm run canary:moneyprinter for a real MP4 canary."
      }
    },
    {
      "id": "render-pro",
      "aliases": ["renderpro"],
      "provider": "render-pro",
      "surface": "worker-reel-id",
      "category": "production",
      "description": "Canonical production renderer for approved Worker reel ids.",
      "smoke": {
        "type": "command",
        "command": "node",
        "args": ["--check", "scripts/render-pro.js"],
        "hint": "Live render-pro needs Worker/R2/Chrome/ffmpeg/voice environment and real reel ids."
      }
    }
  ]
}
