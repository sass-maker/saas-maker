    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@types/react": "19",
    "@types/react-dom": "19",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsup": "8.0.0",
    "typescript": "6.0.3"
  }
}
