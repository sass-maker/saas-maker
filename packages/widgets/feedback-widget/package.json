{
  "name": "@saas-maker/feedback",
  "version": "0.3.0",
  "description": "Drop-in React feedback widget for bugs, feature requests, screenshots, and page-element context.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sass-maker/saas-maker.git",
