{
  "name": "@saas-maker/ai",
  "version": "0.1.0",
  "description": "AI provider integration — config, model discovery, settings UI, and server utilities for any OpenAI-compatible endpoint",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "ai": ">=4.0.0",
    "@ai-sdk/openai-compatible": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "ai": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
