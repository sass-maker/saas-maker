import { initOpsMonitoring, trace } from "@saas-maker/ops";
import { createFoundryDb } from "@saas-maker/db";

/**
 * Foundry Operational Layer
 * Unified entry point for data and monitoring.
 */

// 1. Initialize Monitoring
if (typeof window !== 'undefined') {
  initOpsMonitoring({
    apiKey: process.env.NEXT_PUBLIC_POSTHOG_KEY!,
    projectId: "{{name}}",
  });
}

// 2. Initialize Database (Environment Aware)
export const db = createFoundryDb({
  projectName: "{{name}}",
  // If in Node/Vite (local dev)
  url: process.env.DATABASE_URL,
  authToken: process.env.DATABASE_AUTH_TOKEN,
});

export const fnd = { trace, db };
