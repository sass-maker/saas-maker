import { initOpsMonitoring, trace } from "@saas-maker/ops";
import { createFoundryDb } from "@saas-maker/db";

/**
 * Foundry Operational Layer (Vite/Browser)
 */

// 1. Initialize Monitoring
initOpsMonitoring({
  apiKey: import.meta.env.VITE_POSTHOG_KEY!,
  projectId: "{{name}}",
});

// 2. Initialize Database (LibSQL / Turso)
export const db = createFoundryDb({
  projectName: "{{name}}",
  url: import.meta.env.VITE_DATABASE_URL,
  authToken: import.meta.env.VITE_DATABASE_AUTH_TOKEN,
});

export const fnd = { trace, db };
