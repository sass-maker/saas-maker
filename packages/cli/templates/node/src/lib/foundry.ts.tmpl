import { trace } from "@saas-maker/ops";
import { createFoundryDb } from "@saas-maker/db";

/**
 * Foundry Operational Layer (Node/Worker)
 */

export function createFoundry(env: any) {
  // 1. Initialize Database
  const db = createFoundryDb({
    projectName: "{{name}}",
    d1: env.DB, // Cloudflare D1
    url: env.DATABASE_URL, // Turso
    authToken: env.DATABASE_AUTH_TOKEN,
  });

  return { trace, db };
}
