{
  "name": "@saas-maker/auth-preset",
  "version": "0.1.0",
  "description": "Foundry auth preset — better-auth with D1 + Google + secure cookie defaults baked in.",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "react": "19.2.5"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "drizzle-orm": { "optional": true }
  },
  "devDependencies": {
    "@saas-maker/tsconfig": "workspace:*",
    "@testing-library/react": "16.3.2",
    "@types/react": "19",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "tsup": "8.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
