{
  "name": "@saas-maker/ai",
  "version": "0.1.0",
  "description": "AI provider integration — config, model discovery, settings UI, and server utilities for any OpenAI-compatible endpoint",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@saas-maker/ops": "workspace:*" ,
    "@ai-sdk/openai-compatible": "2.0.41",
    "ai": "6.0.168"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": "2.0.41",
    "ai": "6.0.168",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "2.0.41",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19",
    "@types/react-dom": "19",
    "ai": "6.0.168",
    "happy-dom": "20.9.0",
    "jsdom": "29.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsup": "8.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
