{
  "name": "@saas-maker/sdk",
  "version": "0.3.1",
  "description": "Official SDK for SaaS Maker — drop-in backend services for SaaS apps. Feedback, waitlist, testimonials, changelog, analytics, forms, roadmap, chatbot, AI gateway, and directory.",
  "keywords": [
    "saas",
    "saas-maker",
    "sassmaker",
    "backend-as-a-service",
    "feedback",
    "waitlist",
    "testimonials",
    "changelog",
    "analytics",
    "forms",
    "roadmap",
    "chatbot",
    "ai-gateway",
    "sdk"
  ],
  "homepage": "https://sassmaker.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarthakagrawal927/saas-maker",
    "directory": "packages/sdk"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "8.0.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {},
  "license": "MIT"
}
