---
import { getFleetProjects, getFleetTasks, getMarketingPipeline } from "../lib/fleet-data";

const pipeline = getMarketingPipeline();
const readyStages = pipeline.stages.filter((stage) => stage.state === "ready").length;
const mappedChannels = pipeline.brands.reduce((sum, brand) => sum + brand.mappedChannels.length, 0);
const totalChannels = pipeline.brands.reduce((sum, brand) => sum + brand.channels.length, 0);
const connectedChannels = pipeline.brands.reduce((sum, brand) => sum + brand.connectedChannels.length, 0);
const projectTitles = new Map(getFleetProjects().map((project) => [project.slug, project.title]));
const brandSlugs = new Set(pipeline.brands.map((brand) => brand.slug));
const marketingTasks = getFleetTasks()
  .filter((task) => task.lane === "marketing" && task.status !== "done" && brandSlugs.has(task.projectSlug))
  .sort((left, right) => Number(right.status === "in_progress") - Number(left.status === "in_progress") || Number(right.priority === "high") - Number(left.priority === "high"));
const marketingTaskGroups = pipeline.brands.map((brand) => ({
  slug: brand.slug,
  name: projectTitles.get(brand.slug) ?? brand.name,
  tasks: marketingTasks.filter((task) => task.projectSlug === brand.slug)
}));
const formatDate = (value: string | null) => value
  ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short", timeZone: "Asia/Kolkata" }).format(new Date(value))
  : "No proof yet";
const channelLabel = (channel: string) => ({ instagram_reels: "Instagram", youtube_shorts: "YouTube", tiktok: "TikTok" })[channel] ?? channel;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marketing Pipeline · Fleet Ops</title>
    <meta name="description" content="Read-only Fleet marketing pipeline status by brand, stage, evidence, and publishing account." />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div><p class="eyebrow">Fleet Ops / Marketing</p><h1>Source to channel</h1></div>
        <nav aria-label="Fleet console"><a href="/">Overview</a><a href="/build">Build</a><a class="active" href="/marketing">Market</a><a href="https://swe-interview-prep.pages.dev/sources">Learn</a><a href="/devlog">Devlog</a></nav>
      </header>

      <section class="summary" aria-label="Marketing pipeline summary">
        <div><span>Pipeline stages</span><strong>{readyStages} / {pipeline.stages.length}</strong><small>operational now</small></div>
        <div><span>Brand programs</span><strong>{pipeline.brands.length}</strong><small>{marketingTasks.length} relevant marketing tasks</small></div>
        <div><span>Account routes</span><strong>{mappedChannels} / {totalChannels}</strong><small>{connectedChannels} OAuth connections ready</small></div>
        <div><span>Latest video proof</span><strong>{pipeline.proof?.score ?? "-"}</strong><small>{pipeline.proof ? `${pipeline.proof.verdict} · ${pipeline.proof.durationSeconds}s` : "not run"}</small></div>
      </section>

      <section class="band">
        <div class="section-head"><div><p class="eyebrow">Control plane</p><h2>Pipeline state</h2></div><span>Updated {formatDate(pipeline.updatedAt)}</span></div>
        <div class="stage-list">
          {pipeline.stages.map((stage, index) => (
            <article>
              <span class="index">{String(index + 1).padStart(2, "0")}</span>
              <div><h3>{stage.name}</h3><p>{stage.detail}</p></div>
              <span class:list={["state", stage.state]}>{stage.state.replace("-", " ")}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="band live-band" aria-label="Live marketing queue">
        <div class="section-head"><div><p class="eyebrow">Live queue</p><h2>Approval and release flow</h2></div><span data-marketing-updated>Loading one-minute snapshot</span></div>
        <div class="live-grid">
          <div><strong data-marketing-drafts>-</strong><span>Draft review</span></div>
          <div><strong data-marketing-rendering>-</strong><span>Rendering</span></div>
          <div><strong data-marketing-review>-</strong><span>Posting review</span></div>
          <div><strong data-marketing-scheduled>-</strong><span>Scheduled</span></div>
          <div><strong data-marketing-retrying>-</strong><span>Retrying</span></div>
          <div><strong data-marketing-released>-</strong><span>Released</span></div>
        </div>
      </section>

      <section class="band marketing-task-band" aria-labelledby="marketing-tasks-title">
        <div class="section-head"><div><p class="eyebrow">SaaS Maker tasks</p><h2 id="marketing-tasks-title">Marketing backlog</h2></div><span>{marketingTasks.length} open across registered programs</span></div>
        <div class="marketing-task-groups">
          {marketingTaskGroups.map((group) => (
            <section class="marketing-task-group">
              <header><div><h3>{group.name}</h3><span>{group.tasks.length} open</span></div><a href={`/projects/${group.slug}`}>Project</a></header>
              {group.tasks.length > 0 ? (
                <div class="marketing-task-list">
                  {group.tasks.map((task) => (
                    <div class="marketing-task-row">
                      <span class:list={["state", task.status === "in_progress" ? "ready" : "blocked"]}>{task.status.replace("_", " ")}</span>
                      <strong>{task.title.replace(/^.*?:\s*marketing\s*/i, "")}</strong>
                      <small>{task.priority}{task.claimedBy ? ` · ${task.claimedBy}` : ""}</small>
                    </div>
                  ))}
                </div>
              ) : <p class="empty-marketing">No open marketing tasks.</p>}
            </section>
          ))}
        </div>
      </section>

      <section class="band readiness-band" aria-labelledby="ready-now-title">
        <div class="section-head"><div><p class="eyebrow">Launch readiness</p><h2 id="ready-now-title">What is ready now</h2></div><span>Only social sign-in remains</span></div>
        <div class="readiness-layout">
          <div class="ready-checks">
            <div><span class="check" aria-hidden="true">✓</span><p><strong>3 content sources</strong><small>Read-only product adapters are connected</small></p></div>
            <div><span class="check" aria-hidden="true">✓</span><p><strong>6 channel routes</strong><small>Instagram and YouTube are isolated per brand</small></p></div>
            <div><span class="check" aria-hidden="true">✓</span><p><strong>Two-stage approval</strong><small>Content and publishing require separate decisions</small></p></div>
            <div><span class="check" aria-hidden="true">✓</span><p><strong>Video production</strong><small>Kokoro, Chromium, FFmpeg, and R2 verified</small></p></div>
            <div><span class="check" aria-hidden="true">✓</span><p><strong>Minute runner</strong><small>Retries, deduplication, receipts, and alerts are active</small></p></div>
          </div>
          <aside class="remaining">
            <p class="eyebrow">Remaining input</p>
            <strong>{connectedChannels} / {totalChannels} accounts connected</strong>
            <p>Sign in to each brand's Instagram and YouTube account. Drafting, review, rendering, scheduling, and posting are already wired.</p>
          </aside>
        </div>
      </section>

      <section class="band programs-band">
        <div class="section-head"><div><p class="eyebrow">Programs</p><h2>Brand publishing routes</h2></div><span>Facts stay in each product repository</span></div>
        <div class="program-list">
          {pipeline.brands.map((brand) => (
            <article class="program" data-brand={brand.slug}>
              <div class="program-brand">
                <p class="program-kicker">{brand.name}</p>
                <a href={brand.domain}>{brand.domain.replace(/^https?:\/\//, "")}</a>
                <p>{brand.sourceDetail}</p>
                <span class:list={["compact-state", brand.sourceReady ? "ready" : "blocked"]}>{brand.sourceReady ? "Source ready" : "Source unavailable"}</span>
                <dl class="program-stats">
                  <div><dt>Connection</dt><dd data-brand-connection>{brand.connectedChannels.length}/{brand.channels.length} connected</dd></div>
                  <div><dt>Total posts</dt><dd data-brand-posts>0</dd></div>
                  <div><dt>Last posted</dt><dd data-brand-last-posted>Never</dd></div>
                </dl>
              </div>
              <div class="route-list">
                {brand.channels.map((channel) => {
                  const mapped = brand.mappedChannels.includes(channel);
                  const connected = brand.connectedChannels.includes(channel);
                  return (
                    <div class="route" data-channel={channel}>
                      <div><strong>{channelLabel(channel)}</strong><span>{mapped ? "Brand account route configured" : "Account route missing"}</span></div>
                      <span data-route-state class:list={["route-state", connected ? "connected" : mapped ? "waiting" : "blocked"]}>
                        {connected ? "Connected" : mapped ? "OAuth needed" : "Not routed"}
                      </span>
                    </div>
                  );
                })}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="proof">
        <div><p class="eyebrow">Verified media path</p><h2>{pipeline.proof ? "A real source-backed reel passed" : "No verified render yet"}</h2></div>
        {pipeline.proof && <dl><div><dt>Brand</dt><dd>{pipeline.proof.brand}</dd></div><div><dt>Quality</dt><dd>{pipeline.proof.score} / 100</dd></div><div><dt>Duration</dt><dd>{pipeline.proof.durationSeconds}s</dd></div><div><dt>Source</dt><dd><a href={pipeline.proof.sourceUrl}>Open evidence</a></dd></div></dl>}
        <p>The proof is local and was not posted. Live Instagram and YouTube distribution remains blocked until brand-specific OAuth accounts are connected and an exact distribution request is approved. TikTok/Postiz is deferred and does not count against launch readiness.</p>
      </section>
    </main>
  </body>
</html>

<script>
  const fields = ["drafts", "rendering", "review", "scheduled", "retrying", "released"];
  async function refreshMarketing() {
    try {
      const response = await fetch("/api/runtime", { cache: "no-store" });
      if (!response.ok) throw new Error("runtime unavailable");
      const runtime = await response.json();
      for (const field of fields) {
        const node = document.querySelector(`[data-marketing-${field}]`);
        if (node) node.textContent = String(runtime.marketing?.[field] ?? 0);
      }
      const updated = document.querySelector("[data-marketing-updated]");
      if (updated) updated.textContent = runtime.marketing?.generatedAt
        ? `Readiness checked ${new Date(runtime.marketing.generatedAt).toLocaleString()}`
        : "Marketing runtime is waiting";
      for (const brand of runtime.marketing?.brands ?? []) {
        const program = document.querySelector(`[data-brand="${brand.slug}"]`);
        if (!program) continue;
        const connection = program.querySelector("[data-brand-connection]");
        const posts = program.querySelector("[data-brand-posts]");
        const lastPosted = program.querySelector("[data-brand-last-posted]");
        if (connection) connection.textContent = `${brand.connectedChannels?.length ?? 0}/${brand.channels?.length ?? 0} connected`;
        if (posts) posts.textContent = String(brand.totalPosts ?? 0);
        if (lastPosted) lastPosted.textContent = brand.lastPostedAt
          ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short" }).format(new Date(brand.lastPostedAt))
          : "Never";
        for (const route of program.querySelectorAll("[data-channel]")) {
          const state = route.querySelector("[data-route-state]");
          if (!state) continue;
          const connected = brand.connectedChannels?.includes(route.dataset.channel);
          state.textContent = connected ? "Connected" : "OAuth needed";
          state.className = `route-state ${connected ? "connected" : "waiting"}`;
        }
      }
    } catch {
      const updated = document.querySelector("[data-marketing-updated]");
      if (updated) updated.textContent = "Live queue unavailable";
    }
  }
  refreshMarketing();
  setInterval(refreshMarketing, 60000);
</script>

<style>
  :root{color-scheme:dark;--bg:#090b0c;--surface:#101416;--line:#2b302d;--text:#f3f6f4;--muted:#a6aea9;--mint:#79dcc8;--yellow:#f2c14e;--red:#ff8e8e;--green:#91e49e}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,sans-serif;letter-spacing:0}.shell{width:min(1240px,100%);margin:auto;padding:24px}.topbar{min-height:150px;display:flex;align-items:flex-end;justify-content:space-between;gap:24px;border-bottom:1px solid var(--line);padding-bottom:24px}.eyebrow{margin:0 0 8px;color:var(--mint);font-size:12px;font-weight:800;text-transform:uppercase}h1,h2,h3,p{margin-top:0}h1{margin-bottom:0;font-size:52px;line-height:1}h2{margin-bottom:0;font-size:28px}nav{display:flex;gap:6px}nav a{color:var(--muted);text-decoration:none;border:1px solid var(--line);padding:10px 14px}nav a.active,nav a:hover{color:var(--text);border-color:var(--mint)}.summary{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--line)}.summary div{min-height:145px;padding:24px;border-right:1px solid var(--line);display:grid;align-content:center}.summary div:last-child{border-right:0}.summary span,.summary small,.section-head>span{color:var(--muted)}.summary strong{font-size:40px}.band{padding:44px 0;border-bottom:1px solid var(--line)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:24px}.stage-list{border-top:1px solid var(--line)}.stage-list article{display:grid;grid-template-columns:52px 1fr auto;gap:20px;align-items:center;padding:18px 0;border-bottom:1px solid var(--line)}.index{font:700 13px ui-monospace,monospace;color:var(--muted)}h3{margin-bottom:4px;font-size:17px}.stage-list p,.proof>p{margin-bottom:0;color:var(--muted)}.state{display:inline-flex;width:max-content;border:1px solid var(--line);padding:5px 8px;font:800 11px ui-monospace,monospace;text-transform:uppercase}.state.ready{color:var(--green);border-color:#91e49e66}.state.blocked{color:var(--yellow);border-color:#f2c14e66}.state.not-configured{color:var(--red);border-color:#ff8e8e66}.live-grid{display:grid;grid-template-columns:repeat(6,1fr);border:1px solid var(--line)}.live-grid div{min-height:110px;padding:18px;border-right:1px solid var(--line);display:grid;align-content:center}.live-grid div:last-child{border-right:0}.live-grid strong{font-size:32px}.live-grid span{color:var(--muted);font-size:12px}.readiness-layout{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(280px,.8fr);gap:24px}.ready-checks{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--line)}.ready-checks>div{display:flex;gap:12px;min-height:100px;padding:18px;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}.ready-checks>div:nth-child(2n){border-right:0}.ready-checks>div:nth-last-child(-n+2){border-bottom:0}.ready-checks>div:last-child{border-right:1px solid var(--line)}.check{display:grid;place-items:center;flex:0 0 24px;height:24px;border:1px solid #91e49e66;color:var(--green);font-weight:900}.ready-checks p{margin:1px 0 0}.ready-checks strong,.ready-checks small{display:block}.ready-checks small{margin-top:5px;color:var(--muted);line-height:1.4}.remaining{padding:22px;border:1px solid #f2c14e66;background:#f2c14e0a}.remaining>strong{display:block;font-size:26px;line-height:1.15}.remaining>p:last-child{margin:14px 0 0;color:var(--muted);line-height:1.55}.program-list{border-top:1px solid var(--line)}.program{display:grid;grid-template-columns:minmax(280px,.9fr) minmax(0,1.4fr);gap:36px;padding:28px 0;border-bottom:1px solid var(--line)}.program-brand{min-width:0}.program-kicker{margin:0 0 3px;font-size:19px;font-weight:800}.program-brand>a{display:inline-block;margin-bottom:16px}.program-brand>p:not(.program-kicker){max-width:440px;margin-bottom:14px;color:var(--muted);line-height:1.45}.compact-state,.route-state{display:inline-flex;width:max-content;border:1px solid var(--line);padding:5px 8px;font:800 10px ui-monospace,monospace;text-transform:uppercase}.compact-state.ready,.route-state.connected{color:var(--green);border-color:#91e49e66}.compact-state.blocked,.route-state.blocked{color:var(--red);border-color:#ff8e8e66}.program-stats{display:grid;grid-template-columns:1fr 1fr;margin:18px 0 0;border-top:1px solid var(--line)}.program-stats div{padding:12px 10px 0 0}.program-stats div:last-child{grid-column:1/-1}.program-stats dt{color:var(--muted);font-size:10px;text-transform:uppercase}.program-stats dd{margin:4px 0 0;font-size:13px;font-weight:800}.route-list{display:grid;grid-template-columns:1fr 1fr;gap:10px}.route{display:flex;align-items:center;justify-content:space-between;gap:14px;min-height:88px;padding:16px;border:1px solid var(--line);background:var(--surface)}.route strong,.route div>span{display:block}.route div>span{margin-top:5px;color:var(--muted);font-size:12px}.route-state.waiting{color:var(--yellow);border-color:#f2c14e66}.proof{padding:44px 0 60px;display:grid;grid-template-columns:minmax(260px,1fr) 1.5fr;gap:28px}.proof dl{margin:0;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line)}.proof dl div{padding:16px;background:var(--surface)}dt{color:var(--muted);font-size:11px;text-transform:uppercase}dd{margin:5px 0 0;font-weight:800}.proof>p{grid-column:1/-1;max-width:850px}@media(max-width:760px){.shell{padding:14px}.topbar,.section-head{display:grid}.topbar{min-height:170px}.topbar nav{overflow-x:auto}h1{font-size:40px}.summary{grid-template-columns:1fr 1fr}.summary div{min-height:115px;padding:16px}.summary div:nth-child(2){border-right:0}.live-grid{grid-template-columns:repeat(2,1fr)}.live-grid div:nth-child(2n){border-right:0}.live-grid div{border-bottom:1px solid var(--line)}.readiness-layout,.program,.route-list{grid-template-columns:1fr}.ready-checks{grid-template-columns:1fr}.ready-checks>div,.ready-checks>div:nth-child(2n),.ready-checks>div:nth-last-child(-n+2),.ready-checks>div:last-child{border-right:0;border-bottom:1px solid var(--line)}.ready-checks>div:last-child{border-bottom:0}.program{gap:20px;padding:24px 0}.route{min-height:76px}.proof{grid-template-columns:1fr}.proof dl{grid-template-columns:1fr 1fr}.stage-list article{grid-template-columns:36px 1fr}.stage-list .state{grid-column:2}}
</style>
<style>
  @media(max-width:760px){.topbar nav{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr));overflow:visible!important}.topbar nav a{justify-content:center;padding-inline:8px}.summary div{min-width:0}}
</style>
<style>
  .marketing-task-groups{border-top:1px solid var(--line)}
  .marketing-task-group{display:grid;grid-template-columns:minmax(220px,.65fr) minmax(0,1.6fr);gap:28px;padding:24px 0;border-bottom:1px solid var(--line)}
  .marketing-task-group>header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
  .marketing-task-group>header span,.marketing-task-row small,.empty-marketing{color:var(--muted)}
  .marketing-task-group>header a{color:var(--mint)}
  .marketing-task-list{max-height:430px;overflow-y:auto;border-top:1px solid var(--line)}
  .marketing-task-row{display:grid;grid-template-columns:92px minmax(0,1fr) 90px;gap:14px;align-items:center;min-height:54px;padding:10px 8px;border-bottom:1px solid var(--line)}
  .marketing-task-row strong{font-size:14px;overflow-wrap:anywhere}
  .marketing-task-row small{text-align:right;text-transform:capitalize}
  .empty-marketing{margin:0}
  @media(max-width:760px){.marketing-task-group{grid-template-columns:1fr;gap:16px}.marketing-task-row{grid-template-columns:82px minmax(0,1fr)}.marketing-task-row small{grid-column:2;text-align:left}}
</style>
