---
import FleetNav from "../components/FleetNav.astro";
import {
  buildRiskRegister,
  getResilienceEnvelope,
  groupFindingsByCategory,
  groupFindingsBySeverity
} from "../lib/resilience";

const envelope = getResilienceEnvelope();
const { snapshot, status, stale, adapter, sourcedAt } = envelope;
const bySeverity = groupFindingsBySeverity(snapshot.findings);
const byCategory = groupFindingsByCategory(snapshot.findings);
const riskRegister = buildRiskRegister(envelope);

const failedProbes = snapshot.live.domain_probes.filter((probe) => !probe.ok);
const okProbes = snapshot.live.domain_probes.filter((probe) => probe.ok);
const jobsMissingContract = snapshot.evidence.background_jobs.filter(
  (job) => (job.scheduled && !job.timeout_or_bound) || (job.async && !job.idempotency_or_dedup)
);
const reposMissingConfig = snapshot.evidence.repositories.filter(
  (repo) => repo.wrangler_configs.length === 0 && repo.workflows.length === 0
);

const statusLabel: Record<typeof status, string> = {
  healthy: "Healthy",
  warning: "Warning",
  blocked: "Blocked",
  stale: "Stale",
  unknown: "Unknown"
};

const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short", timeZone: "Asia/Kolkata" }).format(new Date(value))
    : "No data";

const severityLabel: Record<string, string> = { high: "High", medium: "Medium", low: "Low", info: "Info" };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Resilience · Fleet Ops</title>
    <meta
      name="description"
      content="Read-only Fleet resilience view: early warning signals across projects, domains, background jobs, deploys, and Cloudflare inventory. Sanitized; no tokens, IPs, or controls."
    />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <main class="shell">
      <FleetNav active="resilience" />
      <header class="topbar">
        <div>
          <p class="eyebrow">Fleet Ops / Resilience</p>
          <h1>Resilience dashboard</h1>
          <p class="lede">Read-only early warning across projects, surfaces, and background work. No tokens, IPs, headers, raw provider responses, or destructive controls are exposed here.</p>
        </div>
        <p class:list={["status-pill", status]} aria-live="polite" data-status={status}>
          <span class="dot" aria-hidden="true"></span>
          <strong>{statusLabel[status]}</strong>
        </p>
      </header>

      <section class="summary" aria-label="Resilience summary">
        <div>
          <span>Last audit</span>
          <strong data-audit-time>{formatDate(snapshot.generated_at)}</strong>
          <small data-audit-state>{stale ? "Snapshot is stale — treat as historical" : adapter === "fixture" ? "Sanitized fixture fallback" : "From latest audit artifact"}</small>
        </div>
        <div>
          <span>Scope</span>
          <strong>{snapshot.scope.projects}</strong>
          <small>{snapshot.scope.domains} canonical domains</small>
        </div>
        <div>
          <span>High findings</span>
          <strong data-high-count>{bySeverity.high.length}</strong>
          <small>blocking · needs operator action</small>
        </div>
        <div>
          <span>Medium findings</span>
          <strong data-medium-count>{bySeverity.medium.length}</strong>
          <small>actionable early signals</small>
        </div>
        <div>
          <span>Domain probes</span>
          <strong>{okProbes.length}/{snapshot.live.domain_probes.length}</strong>
          <small>{failedProbes.length} failing</small>
        </div>
        <div>
          <span>Live checks</span>
          <strong>{snapshot.live_checks ? "On" : "Off"}</strong>
          <small>repo scan {snapshot.repository_scan ? "included" : "skipped"}</small>
        </div>
      </section>

      {stale && (
        <section class="banner stale" aria-label="Stale snapshot warning">
          <strong>Stale snapshot.</strong>
          <span>This resilience view is older than 7 days. Do not treat it as a live signal — re-run <code>fleet-ops/scripts/cloudflare-resilience-audit.mjs</code> before acting.</span>
        </section>
      )}
      {status === "unknown" && (
        <section class="banner unknown" aria-label="No resilience data">
          <strong>No resilience data.</strong>
          <span>No audit artifact or fixture was available. Run the audit script to populate <code>.symphony/cloudflare-resilience/latest.json</code>.</span>
        </section>
      )}

      <section id="probes" class="band" aria-labelledby="probes-title">
        <div class="section-head">
          <div><p class="eyebrow">Surface coverage</p><h2 id="probes-title">Pages and domain probes</h2></div>
          <span>{snapshot.live.domain_probes.length} probes · {snapshot.live.cloudflare.pages_count ?? "—"} Pages projects in inventory</span>
        </div>
        {snapshot.live.domain_probes.length === 0 ? (
          <p class="empty" data-empty-probes>No domain probe evidence in this snapshot. Live checks may be disabled.</p>
        ) : (
          <div class="probe-list" role="table" aria-label="Domain probe results">
            <div class="probe-row probe-head" role="row"><span>Domain</span><span>Status</span><span>Result</span><span>Latency</span></div>
            {snapshot.live.domain_probes.map((probe) => (
              <div class="probe-row" role="row" data-probe-ok={probe.ok}>
                <span>{probe.domain}</span>
                <strong>{probe.status ?? "—"}</strong>
                <span class:list={["probe-state", probe.ok ? "ok" : "fail"]}>{probe.ok ? "ok" : "failed"}</span>
                <span>{probe.duration_ms} ms</span>
              </div>
            ))}
          </div>
        )}
        {snapshot.live.cloudflare.error && (
          <p class="note">Cloudflare inventory unavailable: {snapshot.live.cloudflare.error}. Counts hidden.</p>
        )}
        <ul class="inventory-summary" aria-label="Cloudflare inventory counts">
          <li><span>Pages</span><strong>{snapshot.live.cloudflare.pages_count ?? "—"}</strong></li>
          <li><span>Queues</span><strong>{snapshot.live.cloudflare.queues_count ?? "—"}</strong></li>
          <li><span>Workflows</span><strong>{snapshot.live.cloudflare.workflows_count ?? "—"}</strong></li>
        </ul>
      </section>

      <section id="findings" class="band" aria-labelledby="findings-title">
        <div class="section-head">
          <div><p class="eyebrow">Findings</p><h2 id="findings-title">By severity and category</h2></div>
          <span>{snapshot.findings.length} total · {bySeverity.low.length} low inspectable in detail</span>
        </div>
        {snapshot.findings.length === 0 ? (
          <p class="empty" data-empty-findings>No findings in this snapshot.</p>
        ) : (
          <div class="findings-grid">
            <article class="finding-card high" aria-label="High severity findings">
              <header><span class="sev high">High</span><strong>{bySeverity.high.length}</strong></header>
              <ul>{bySeverity.high.map((f) => <li><code>{f.surface}</code><p>{f.evidence}</p><small>Next: {f.next_action}</small></li>)}</ul>
              {bySeverity.high.length === 0 && <p class="empty">None.</p>}
            </article>
            <article class="finding-card medium" aria-label="Medium severity findings">
              <header><span class="sev medium">Medium</span><strong>{bySeverity.medium.length}</strong></header>
              <ul>{bySeverity.medium.map((f) => <li><code>{f.surface}</code><p>{f.evidence}</p><small>Next: {f.next_action}</small></li>)}</ul>
              {bySeverity.medium.length === 0 && <p class="empty">None.</p>}
            </article>
            <article class="finding-card low" aria-label="Low severity findings">
              <header><span class="sev low">Low</span><strong>{bySeverity.low.length}</strong></header>
              <details>
                <summary>Inspect low findings</summary>
                <ul>{bySeverity.low.map((f) => <li><code>{f.surface}</code><p>{f.evidence}</p><small>Next: {f.next_action}</small></li>)}</ul>
                {bySeverity.low.length === 0 && <p class="empty">None.</p>}
              </details>
            </article>
          </div>
        )}

        {byCategory.length > 0 && (
          <div class="category-table" role="table" aria-label="Findings by category">
            <div class="category-row category-head" role="row"><span>Category</span><span>High</span><span>Medium</span><span>Low</span><span>Info</span></div>
            {byCategory.map(([category, items]) => (
              <div class="category-row" role="row">
                <span>{category}</span>
                <strong>{items.filter((f) => f.severity === "high").length}</strong>
                <strong>{items.filter((f) => f.severity === "medium").length}</strong>
                <strong>{items.filter((f) => f.severity === "low").length}</strong>
                <strong>{items.filter((f) => f.severity === "info").length}</strong>
              </div>
            ))}
          </div>
        )}
      </section>

      <section id="jobs" class="band" aria-labelledby="jobs-title">
        <div class="section-head">
          <div><p class="eyebrow">Background jobs</p><h2 id="jobs-title">Evidence and missing contract fields</h2></div>
          <span>{snapshot.evidence.background_jobs.length} jobs with async/scheduled evidence</span>
        </div>
        {snapshot.evidence.background_jobs.length === 0 ? (
          <p class="empty" data-empty-jobs>No background-job evidence in this snapshot.</p>
        ) : (
          <div class="job-table" role="table" aria-label="Background job contract evidence">
            <div class="job-row job-head" role="row"><span>Surface</span><span>Scheduled</span><span>Async</span><span>Timeout</span><span>Concurrency</span><span>Idempotency</span></div>
            {snapshot.evidence.background_jobs.map((job) => {
              const missing = [
                job.scheduled && !job.timeout_or_bound ? "timeout" : null,
                job.async && !job.idempotency_or_dedup ? "idempotency" : null
              ].filter(Boolean);
              return (
                <div class="job-row" role="row" data-job-missing={missing.join(",") || undefined}>
                  <span>{job.id}</span>
                  <span class:list={["flag", job.scheduled ? "yes" : "no"]}>{job.scheduled ? "yes" : "no"}</span>
                  <span class:list={["flag", job.async ? "yes" : "no"]}>{job.async ? "yes" : "no"}</span>
                  <span class:list={["flag", job.timeout_or_bound ? "yes" : "no"]}>{job.timeout_or_bound ? "yes" : "no"}</span>
                  <span class:list={["flag", job.concurrency_or_lease ? "yes" : "no"]}>{job.concurrency_or_lease ? "yes" : "no"}</span>
                  <span class:list={["flag", job.idempotency_or_dedup ? "yes" : "no"]}>{job.idempotency_or_dedup ? "yes" : "no"}</span>
                </div>
              );
            })}
          </div>
        )}
        {jobsMissingContract.length > 0 && (
          <p class="note">{jobsMissingContract.length} job(s) missing timeout or idempotency evidence — see risk register.</p>
        )}
      </section>

      <section id="deploys" class="band" aria-labelledby="deploys-title">
        <div class="section-head">
          <div><p class="eyebrow">Build and deploy</p><h2 id="deploys-title">Failures and smoke status</h2></div>
          <span>{snapshot.evidence.repositories.length} repositories scanned</span>
        </div>
        <div class="deploy-grid">
          <article class="deploy-card" aria-label="Blocking deploys">
            <header><span class="sev high">Blocking</span></header>
            <strong>{snapshot.findings.filter((f) => f.severity === "high" && /deploy|preview-hygiene|live-surface/.test(f.category)).length}</strong>
            <p>High-severity deploy, preview-hygiene, or live-surface findings.</p>
          </article>
          <article class="deploy-card" aria-label="Smoke gaps">
            <header><span class="sev medium">Smoke gaps</span></header>
            <strong>{snapshot.findings.filter((f) => f.category === "deploy" && f.severity === "medium").length}</strong>
            <p>Deploy workflows missing a post-deploy smoke/health check.</p>
          </article>
          <article class="deploy-card" aria-label="Repositories without deploy config">
            <header><span class="sev low">No config</span></header>
            <strong>{reposMissingConfig.length}</strong>
            <p>Repositories with no tracked wrangler config or GitHub workflow.</p>
          </article>
        </div>
      </section>

      <section id="inventory" class="band" aria-labelledby="inventory-title">
        <div class="section-head">
          <div><p class="eyebrow">Inventory</p><h2 id="inventory-title">Queue, workflow, and deployment evidence</h2></div>
          <span>Counts only — raw provider responses are not exposed</span>
        </div>
        <div class="inventory-grid">
          <article><span>Pages projects</span><strong>{snapshot.live.cloudflare.pages_count ?? "—"}</strong><small>from live Cloudflare inventory</small></article>
          <article><span>Queues</span><strong>{snapshot.live.cloudflare.queues_count ?? "—"}</strong><small>from <code>wrangler queues list</code></small></article>
          <article><span>Workflows</span><strong>{snapshot.live.cloudflare.workflows_count ?? "—"}</strong><small>from <code>wrangler workflows list</code></small></article>
          <article><span>Repositories scanned</span><strong>{snapshot.evidence.repositories.length}</strong><small>with wrangler config and workflow evidence</small></article>
        </div>
      </section>

      <section id="risk" class="band" aria-labelledby="risk-title">
        <div class="section-head">
          <div><p class="eyebrow">Risk register</p><h2 id="risk-title">Forward-looking early signals</h2></div>
          <span>{riskRegister.length} entries · operator action only, no controls</span>
        </div>
        {riskRegister.length === 0 ? (
          <p class="empty" data-empty-risk>No early signals in this snapshot.</p>
        ) : (
          <ol class="risk-list">
            {riskRegister.map((entry) => (
              <li class:list={["risk-row", entry.severity]}>
                <span class:list={["sev", entry.severity]}>{severityLabel[entry.severity]}</span>
                <div>
                  <p>{entry.signal}</p>
                  <small>Surface: {entry.surfaces.join(", ")}</small>
                  <small>Action: {entry.action}</small>
                </div>
              </li>
            ))}
          </ol>
        )}
      </section>

      <section id="seam" class="band seam" aria-labelledby="seam-title">
        <div class="section-head">
          <div><p class="eyebrow">Consolidation path</p><h2 id="seam-title">Future ingestion and auth seam</h2></div>
          <span>Adapter: <code>{adapter}</code> · schema v{envelope.schemaVersion} · sourced {formatDate(sourcedAt)}</span>
        </div>
        <div class="seam-grid">
          <article>
            <h3>Current v1 source</h3>
            <p>Reads <code>.symphony/cloudflare-resilience/latest.json</code> produced by the read-only audit script, with a checked-in sanitized fixture as offline fallback. The UI consumes a single <code>ResilienceEnvelope</code> shape — never the raw audit JSON.</p>
          </article>
          <article>
            <h3>Consolidation step (no UI redesign)</h3>
            <p>Replace the file read in <code>src/lib/resilience.ts</code> with a fetch to a signed artifact endpoint behind Cloudflare Access. Bump the adapter label to <code>signed-api</code>; keep <code>schemaVersion</code> stable unless a field breaks. Token storage and the Access policy are deploy-time concerns, owned outside this PRD.</p>
          </article>
          <article>
            <h3>Auth boundary</h3>
            <p>This public route stays sanitized. Any private view (raw responses, IPs, headers, controls) lives behind a separate Access-gated route, not by adding fields here. The sanitization layer in the adapter is the durable boundary.</p>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root{color-scheme:dark;--bg:#090b0c;--surface:#101416;--line:#2b302d;--text:#f3f6f4;--muted:#a6aea9;--mint:#79dcc8;--yellow:#f2c14e;--red:#ff8e8e;--green:#91e49e}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,sans-serif;letter-spacing:0;line-height:1.45}code{font-family:"SFMono-Regular",Menlo,Monaco,Consolas,monospace;color:var(--mint);overflow-wrap:anywhere}.shell{width:min(1240px,100%);margin:auto;padding:24px}.topbar{min-height:150px;display:flex;align-items:flex-end;justify-content:space-between;gap:24px;border-bottom:1px solid var(--line);padding-bottom:24px}.eyebrow{margin:0 0 8px;color:var(--mint);font-size:12px;font-weight:800;text-transform:uppercase}h1,h2,h3,p{margin-top:0}h1{margin-bottom:8px;font-size:48px;line-height:1}h2{margin-bottom:0;font-size:26px}h3{margin-bottom:6px;font-size:16px}.lede{margin:0;max-width:640px;color:var(--muted);font-size:14px}
  .status-pill{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);padding:8px 14px;background:var(--surface);font-size:13px}.status-pill .dot{width:9px;height:9px;border-radius:50%;background:var(--muted)}.status-pill.healthy{border-color:#91e49e66;color:var(--green)}.status-pill.healthy .dot{background:var(--green)}.status-pill.warning{border-color:#f2c14e66;color:var(--yellow)}.status-pill.warning .dot{background:var(--yellow)}.status-pill.blocked{border-color:#ff8e8e66;color:var(--red)}.status-pill.blocked .dot{background:var(--red)}.status-pill.stale{border-color:#f2c14e66;color:var(--yellow)}.status-pill.stale .dot{background:var(--yellow)}.status-pill.unknown{border-color:var(--line);color:var(--muted)}.status-pill.unknown .dot{background:var(--muted)}
  .summary{display:grid;grid-template-columns:repeat(6,1fr);border-bottom:1px solid var(--line)}.summary div{min-height:130px;padding:20px;border-right:1px solid var(--line);display:grid;align-content:center}.summary div:last-child{border-right:0}.summary span,.summary small{color:var(--muted)}.summary small{font-size:11px}.summary strong{font-size:30px}
  .banner{padding:16px 18px;border:1px solid var(--line);border-left-width:3px;background:var(--surface);margin:24px 0}.banner.stale{border-left-color:var(--yellow)}.banner.unknown{border-left-color:var(--muted)}.banner strong{display:inline-block;margin-right:8px}.banner span{color:var(--muted)}
  .band{padding:40px 0;border-bottom:1px solid var(--line)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:20px}.section-head>span{color:var(--muted);font-size:12px;overflow-wrap:anywhere}
  .empty,.note{margin:0;color:var(--muted);font-size:13px}.note{margin-top:12px}
  .probe-list,.job-table,.category-table{border-top:1px solid var(--line)}.probe-row,.job-row,.category-row{display:grid;align-items:center;border-bottom:1px solid var(--line);padding:12px 8px}.probe-row{grid-template-columns:1.6fr .8fr .8fr .8fr}.probe-head,.job-head,.category-head{color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.04em}.probe-row[data-probe-ok="false"] .probe-state{color:var(--red)}.probe-state.ok{color:var(--green)}.probe-state.fail{color:var(--red)}
  .inventory-summary{display:flex;gap:24px;list-style:none;margin:16px 0 0;padding:0}.inventory-summary li{display:flex;flex-direction:column}.inventory-summary span{color:var(--muted);font-size:10px;text-transform:uppercase}.inventory-summary strong{font-size:22px}
  .findings-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.finding-card{min-height:160px;padding:18px;border:1px solid var(--line);background:var(--surface);display:grid;gap:10px;align-content:start}.finding-card header{display:flex;align-items:center;justify-content:space-between}.finding-card strong{font-size:26px}.finding-card ul{margin:0;padding:0;list-style:none;display:grid;gap:10px}.finding-card li{display:grid;gap:4px;border-top:1px solid var(--line);padding-top:10px}.finding-card li p{margin:0;color:var(--text);font-size:13px}.finding-card li small{color:var(--muted);font-size:11px}.finding-card li code{font-size:11px}.finding-card .empty{margin:0}.sev{display:inline-flex;border:1px solid var(--line);padding:3px 8px;font:800 10px ui-monospace,monospace;text-transform:uppercase}.sev.high{color:var(--red);border-color:#ff8e8e66}.sev.medium{color:var(--yellow);border-color:#f2c14e66}.sev.low{color:var(--mint);border-color:#79dcc866}.sev.info{color:var(--muted)}
  .category-row{grid-template-columns:1.6fr repeat(4,1fr)}.category-row strong{font-size:14px}
  .job-row{grid-template-columns:1.4fr repeat(5,.8fr)}.job-row span{font-size:12px}.flag.yes{color:var(--green)}.flag.no{color:var(--muted)}.job-row[data-job-missing] .flag.no{color:var(--yellow)}
  .deploy-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.deploy-card{min-height:130px;padding:18px;border:1px solid var(--line);background:var(--surface);display:grid;gap:8px;align-content:start}.deploy-card strong{font-size:30px}.deploy-card p{margin:0;color:var(--muted);font-size:12px}
  .inventory-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}.inventory-grid article{min-height:120px;padding:18px;border:1px solid var(--line);background:var(--surface);display:grid;gap:6px;align-content:start}.inventory-grid article span{color:var(--muted);font-size:10px;text-transform:uppercase}.inventory-grid article strong{font-size:26px}.inventory-grid article small{color:var(--muted);font-size:11px}
  .risk-list{margin:0;padding:0;list-style:none;border-top:1px solid var(--line)}.risk-row{display:grid;grid-template-columns:80px 1fr;gap:16px;padding:14px 8px;border-bottom:1px solid var(--line)}.risk-row p{margin:0 0 4px;font-size:14px}.risk-row small{display:block;color:var(--muted);font-size:11px}
  .seam-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.seam-grid article{padding:18px;border:1px dashed var(--line);background:var(--surface)}.seam-grid p{margin:0;color:var(--muted);font-size:13px}
  @media(max-width:900px){.summary{grid-template-columns:repeat(3,1fr)}.findings-grid,.deploy-grid,.inventory-grid,.seam-grid{grid-template-columns:1fr}.probe-row{grid-template-columns:1.4fr .7fr .7fr .7fr}.job-row{grid-template-columns:1.2fr repeat(5,.7fr);font-size:11px}.category-row{grid-template-columns:1.2fr repeat(4,.8fr)}}
  @media(max-width:640px){.summary{grid-template-columns:repeat(2,1fr)}.summary div{min-height:110px}.probe-row,.job-row,.category-row{grid-template-columns:1fr;gap:4px}.probe-head,.job-head,.category-head{display:none}.risk-row{grid-template-columns:1fr;gap:8px}.topbar{flex-direction:column;align-items:flex-start;gap:16px}}
</style>
