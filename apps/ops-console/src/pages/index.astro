---
import { getCronJobs, getFleetProjects, getSnapshotInfo, getWifiSummary } from "../lib/fleet-data";

const cronJobs = getCronJobs();
const wifi = getWifiSummary();
const projects = getFleetProjects();
const snapshot = getSnapshotInfo();
const activeJobs = cronJobs.filter((job) => job.enabled);
const heavyJobs = cronJobs.filter((job) => job.effort === "high").length;
const wifiMax = Math.max(...wifi.sparkline, 1);
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", {
        dateStyle: "medium",
        timeStyle: "short",
        timeZone: "Asia/Kolkata"
      }).format(new Date(value))
    : "No data";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fleet Ops Console</title>
    <meta
      name="description"
      content="Public Fleet Ops control-plane view for Codex cron schedules and Wi-Fi Watch telemetry."
    />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="eyebrow">Fleet Ops</p>
          <h1>Machine-run control plane</h1>
        </div>
        <nav class="topnav" aria-label="Fleet console">
          <a href="/">Overview</a>
          <a href="/projects">Projects</a>
          <a href="/connections">Connections</a>
        </nav>
      </header>

      <section class="hero-grid" aria-label="Fleet Ops summary">
        <article class="summary-card primary">
          <div>
            <p class="label">Codex cron</p>
            <strong>{activeJobs.length}</strong>
          </div>
          <span>Full machine-run set converted from Codex app schedules.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">High-effort jobs</p>
            <strong>{heavyJobs}</strong>
          </div>
          <span>Audit, product review, and backlog routing lanes.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">Wi-Fi Watch</p>
            <strong>{wifi.health}</strong>
          </div>
          <span>{wifi.latestMbps ?? "-"} Mbps latest probe across {wifi.sampleCount} tracked samples.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">Projects</p>
            <strong>{projects.length}</strong>
          </div>
          <span>Read-only project state, work queues, smoke, and relationships.</span>
        </article>
      </section>

      <section class="panel update-panel" aria-label="Update cadence">
        <strong>Read-only snapshot</strong>
        <span>{snapshot.refreshCadence}</span>
        <span>Generated {formatDate(snapshot.generatedAt)}</span>
      </section>

      <section class="content-grid">
        <section class="panel cron-panel" aria-labelledby="cron-title">
          <div class="panel-head">
            <div>
              <p class="eyebrow">Schedules</p>
              <h2 id="cron-title">Codex app schedules now running as cron</h2>
            </div>
            <code>fleet-ops/automation/codex-cron/jobs.tsv</code>
          </div>

          <div class="jobs">
            {
              cronJobs.map((job) => (
                <article class="job-card">
                  <div class="job-head">
                    <div>
                      <h3>{job.name}</h3>
                      <code>{job.id}</code>
                    </div>
                    <span class:list={["job-state", job.enabled ? "on" : "off"]}>
                      {job.enabled ? "active" : "off"}
                    </span>
                  </div>
                  <dl>
                    <div>
                      <dt>When</dt>
                      <dd>{job.nextHint}</dd>
                    </div>
                    <div>
                      <dt>Cron</dt>
                      <dd><code>{job.cron}</code></dd>
                    </div>
                    <div>
                      <dt>Model</dt>
                      <dd>{job.model} / {job.effort}</dd>
                    </div>
                    <div>
                      <dt>Lock</dt>
                      <dd>{job.lockMinutes} min</dd>
                    </div>
                  </dl>
                  <details>
                    <summary>Prompt summary</summary>
                    <p>{job.promptSummary}</p>
                  </details>
                </article>
              ))
            }
          </div>
        </section>

        <aside class="side-stack">
          <section class="panel wifi-panel" aria-labelledby="wifi-title">
            <div class="panel-head compact">
              <div>
                <p class="eyebrow">Fleet product</p>
                <h2 id="wifi-title">Wi-Fi Watch</h2>
              </div>
              <span class:list={["health", wifi.health]}>{wifi.health}</span>
            </div>
            <div class="wifi-number">
              <strong>{wifi.latestMbps ?? "-"}</strong>
              <span>latest Mbps</span>
            </div>
            <div class="sparkline" aria-label="Recent Wi-Fi speed samples">
              {
                wifi.sparkline.map((value) => (
                  <i style={`height: ${Math.max(10, Math.round((value / wifiMax) * 100))}%`} />
                ))
              }
            </div>
            <dl class="facts">
              <div>
                <dt>Average probe</dt>
                <dd>{wifi.averageMbps ?? "-"} Mbps</dd>
              </div>
              <div>
                <dt>Events</dt>
                <dd>{wifi.eventCount}</dd>
              </div>
              <div>
                <dt>Incidents, 24h</dt>
                <dd>{wifi.incidents24h}</dd>
              </div>
              <div>
                <dt>Latest sample</dt>
                <dd>{formatDate(wifi.latestSampleAt)}</dd>
              </div>
            </dl>
            <p class="note">
              Linked from <code>{wifi.productPath}</code>. Local network identifiers and raw diagnostics stay private.
            </p>
          </section>

          <section class="panel commands-panel" aria-labelledby="commands-title">
            <div class="panel-head compact">
              <div>
                <p class="eyebrow">Runbook</p>
                <h2 id="commands-title">Machine controls</h2>
              </div>
            </div>
            <ul>
              <li><code>fleet-ops/scripts/agent-stack.sh resume</code><span>OpenClaw plus cron</span></li>
              <li><code>fleet-ops/scripts/agent-stack.sh pause</code><span>stop gateway and cron</span></li>
              <li><code>run-codex-cron &lt;job&gt; --dry-run</code><span>single-job check</span></li>
            </ul>
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #0f1110;
    --panel: #171a18;
    --panel-strong: #1f2623;
    --line: #333a36;
    --text: #f4f6f8;
    --muted: #aab3bd;
    --green: #8ce99a;
    --cyan: #76d7c4;
    --yellow: #ffd166;
    --red: #ff8787;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      linear-gradient(180deg, rgba(118, 215, 196, 0.08), transparent 320px),
      var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.45;
  }

  code,
  pre {
    font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
  }

  code {
    color: var(--cyan);
    overflow-wrap: anywhere;
  }

  .shell {
    width: min(1440px, 100%);
    margin: 0 auto;
    padding: 24px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 148px;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow,
  .label {
    margin: 0 0 6px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0;
    max-width: 840px;
    font-size: clamp(36px, 6vw, 76px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 0;
    font-size: 22px;
  }

  h3 {
    margin-bottom: 4px;
    font-size: 16px;
  }

  .status-pill,
  .job-state,
  .health {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 10px;
    color: var(--muted);
    background: #111518;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .topnav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .topnav a {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    color: var(--muted);
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .summary-card,
  .panel,
  .job-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .summary-card {
    min-height: 142px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .summary-card.primary {
    background:
      linear-gradient(135deg, rgba(118, 215, 196, 0.12), transparent 70%),
      var(--panel-strong);
  }

  .summary-card strong {
    display: block;
    font-size: 38px;
    line-height: 1;
    text-transform: capitalize;
  }

  .summary-card span,
  .note,
  .commands-panel span {
    color: var(--muted);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 16px;
    align-items: start;
  }

  .update-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--muted);
  }

  .update-panel strong {
    color: var(--text);
  }

  .panel {
    padding: 16px;
  }

  .panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .panel-head.compact {
    align-items: center;
  }

  .jobs {
    display: grid;
    gap: 12px;
  }

  .job-card {
    padding: 14px;
    background: #131614;
  }

  .job-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 14px;
  }

  .job-state.on,
  .health.healthy {
    border-color: rgba(140, 233, 154, 0.45);
    color: var(--green);
    background: rgba(140, 233, 154, 0.08);
  }

  .health.degraded,
  .health.connected_no_bandwidth,
  .health.unknown {
    border-color: rgba(255, 209, 102, 0.45);
    color: var(--yellow);
    background: rgba(255, 209, 102, 0.08);
  }

  .health.offline {
    border-color: rgba(255, 135, 135, 0.45);
    color: var(--red);
    background: rgba(255, 135, 135, 0.08);
  }

  dl {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin: 0;
  }

  dt {
    color: var(--muted);
    font-size: 12px;
  }

  dd {
    margin: 3px 0 0;
    font-weight: 700;
  }

  details {
    margin-top: 14px;
    border-top: 1px solid var(--line);
    padding-top: 12px;
  }

  summary {
    cursor: pointer;
    color: var(--cyan);
    font-weight: 700;
  }

  pre {
    margin: 12px 0 0;
    white-space: pre-wrap;
    color: var(--muted);
    background: #0b0e10;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    font-size: 12px;
  }

  details p {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .side-stack {
    display: grid;
    gap: 16px;
  }

  .wifi-number {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 14px;
  }

  .wifi-number strong {
    font-size: 58px;
    line-height: 1;
  }

  .sparkline {
    display: flex;
    align-items: end;
    gap: 3px;
    height: 74px;
    margin: 0 0 16px;
    padding: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #0c0f0d;
  }

  .sparkline i {
    flex: 1;
    min-width: 3px;
    border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, var(--green), var(--cyan));
  }

  .facts {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .note {
    margin: 16px 0 0;
  }

  .commands-panel ul {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .commands-panel li {
    display: grid;
    gap: 4px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }

  .commands-panel li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }

    .cron-panel {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .shell {
      padding: 14px;
    }

    .topbar {
      min-height: 132px;
      align-content: end;
    }

    .topbar,
    .panel-head,
    .job-head {
      display: grid;
    }

    .topnav {
      justify-content: stretch;
    }

    .topnav a {
      justify-content: center;
    }

    .hero-grid,
    .content-grid,
    dl,
    .facts {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 42px;
    }

    .summary-card {
      min-height: 120px;
    }

    .panel {
      padding: 14px;
    }

    .panel-head > code {
      font-size: 11px;
    }
  }
</style>
