---
import { getCronJobs, getDomainIntelligence, getFleetNodes, getFleetProjects, getSnapshotInfo, getWifiSummary } from "../lib/fleet-data";

const cronJobs = getCronJobs();
const wifi = getWifiSummary();
const domains = getDomainIntelligence();
const projects = getFleetProjects();
const productProjects = projects.filter((project) => !["fleet-ops", "wifi-watch"].includes(project.slug));
const productCount = productProjects.length;
const nodes = getFleetNodes();
const snapshot = getSnapshotInfo();
const activeJobs = cronJobs.filter((job) => job.enabled);
const heavyJobs = cronJobs.filter((job) => job.effort === "high").length;
const hostingCounts = projects.reduce<Record<string, number>>((acc, project) => {
  acc[project.hostingLabel] = (acc[project.hostingLabel] ?? 0) + 1;
  return acc;
}, {});
const wifiMax = Math.max(...wifi.sparkline, 1);
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", {
        dateStyle: "medium",
        timeStyle: "short",
        timeZone: "Asia/Kolkata"
      }).format(new Date(value))
    : "No data";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fleet Ops Console</title>
    <meta
      name="description"
      content="Public, read-only status for Fleet projects, schedules, hosting, and sanitized machine health."
    />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="eyebrow">Fleet Ops</p>
          <h1>Fleet status</h1>
        </div>
        <nav class="topnav" aria-label="Fleet console">
          <a class="active" href="/">Overview</a>
          <a href="/build">Build</a>
          <a href="/marketing">Market</a>
          <a href="https://swe-interview-prep.pages.dev/sources">Learn</a>
        </nav>
      </header>

      <nav class="lane-grid" aria-label="Fleet operating tabs">
        <a href="/build">
          <span>01</span>
          <strong>Build</strong>
          <small>Active work and execution queue</small>
        </a>
        <a href="https://swe-interview-prep.pages.dev/sources">
          <span>02</span>
          <strong>Learn</strong>
          <small>Daily sessions and project roadmaps</small>
        </a>
        <a href="/marketing">
          <span>03</span>
          <strong>Market</strong>
          <small>Focus products and distribution</small>
        </a>
      </nav>

      <section class="hero-grid" aria-label="Fleet Ops summary">
        <article class="summary-card primary">
          <div>
            <p class="label">Codex cron</p>
            <strong>{activeJobs.length}</strong>
          </div>
          <span>Full machine-run set converted from Codex app schedules.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">High-effort jobs</p>
            <strong>{heavyJobs}</strong>
          </div>
          <span>Audit, product review, and backlog routing lanes.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">Wi-Fi Watch</p>
            <strong>{wifi.health}</strong>
          </div>
          <span>{wifi.latestMbps ?? "-"} Mbps latest probe across {wifi.sampleCount} tracked samples.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">Projects</p>
            <strong>{productCount}</strong>
          </div>
          <span>Products, plus Fleet Ops and Wi-Fi telemetry as separate operational surfaces.</span>
        </article>
        <article class="summary-card">
          <div>
            <p class="label">Fleet nodes</p>
            <strong>{nodes.length}</strong>
          </div>
          <span>Primary Mac is the only active Fleet control node for now.</span>
        </article>
      </section>

      <section class="panel update-panel" aria-label="Update cadence">
        <strong>Read-only snapshot</strong>
        <span data-heartbeat-at>Last heartbeat loading</span>
        <span data-heartbeat-state>Machine state loading</span>
        <span data-notification-state>Notification queue loading</span>
        <span data-task-state>Agent tasks loading</span>
        <span>{snapshot.refreshCadence}</span>
        <span>Tasks {formatDate(snapshot.tasksSyncedAt)} · Smoke {formatDate(snapshot.smokeGeneratedAt)} · Audit {formatDate(snapshot.auditGeneratedAt)}</span>
      </section>

      <section class="panel hosting-panel" aria-label="Hosting split">
        <div class="panel-head compact">
          <div>
            <p class="eyebrow">Hosting</p>
            <h2>Where things run</h2>
          </div>
          <a href="#projects">Inspect projects</a>
        </div>
        <div class="hosting-grid">
          {Object.entries(hostingCounts).map(([label, count]) => <article><strong>{count}</strong><span>{label}</span></article>)}
        </div>
      </section>

      <section id="projects" class="panel project-panel" aria-labelledby="projects-title">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Projects</p>
            <h2 id="projects-title">Product inventory</h2>
          </div>
          <span>{productProjects.length} products · Fleet Ops and Wi-Fi Watch shown separately</span>
        </div>
        <div class="project-directory">
          {productProjects.map((project) => (
            <a class="project-item" href={`/projects/${project.slug}`}>
              <div class="project-title">
                <span class:list={["project-state", project.state]}>{project.stateLabel}</span>
                <span class:list={["project-hosting", project.hostingKind]}>{project.hostingLabel}</span>
                <h3>{project.title}</h3>
                <p>{project.desc}</p>
              </div>
              <dl>
                <div><dt>Lane</dt><dd>{project.lane}</dd></div>
                <div><dt>Open</dt><dd>{project.openTasks.length}</dd></div>
                <div><dt>Blocked</dt><dd>{project.blockedTasks}</dd></div>
                <div><dt>Updated</dt><dd>{formatDate(project.updatedAt)}</dd></div>
              </dl>
            </a>
          ))}
        </div>
      </section>

      <section class="panel domain-panel" aria-labelledby="domains-title">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Domain intelligence</p>
            <h2 id="domains-title">drank + PSI Swarm</h2>
          </div>
          <span>Weekly owned-domain snapshot</span>
        </div>
        <div class="domain-table" role="table" aria-label="Domain rating and performance results">
          <div class="domain-row domain-head" role="row"><span>Domain</span><span>DR</span><span>Performance</span><span>LCP</span><span>CLS</span><span>Updated</span></div>
          {domains.map((domain) => (
            <div class="domain-row" role="row" data-domain={domain.domain}>
              <a href={`https://${domain.domain}`}>{domain.domain}</a>
              <strong data-domain-rating>{domain.domainRating ?? "-"}</strong>
              <strong data-domain-score class:list={[domain.performanceScore !== null && domain.performanceScore >= 90 ? "good" : domain.performanceScore !== null && domain.performanceScore >= 50 ? "warn" : "bad"]}>{domain.performanceScore !== null ? Math.round(domain.performanceScore) : "Pending"}</strong>
              <span data-domain-lcp>{domain.lcpMs !== null ? `${(domain.lcpMs / 1000).toFixed(2)}s` : "Pending"}</span>
              <span data-domain-cls>{domain.cls !== null ? domain.cls.toFixed(3) : "Pending"}</span>
              <time data-domain-updated datetime={domain.psiUpdatedAt ?? domain.domainRatingUpdatedAt ?? undefined}>{formatDate(domain.psiUpdatedAt ?? domain.domainRatingUpdatedAt)}</time>
            </div>
          ))}
        </div>
      </section>

      <section id="mobile-control" class="panel node-panel" aria-label="Machine and mobile control state">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Mobile control</p>
            <h2>Machines, agents, and private access</h2>
          </div>
          <code>mobile-control status</code>
        </div>
        <div class="node-grid">
          {
            nodes.map((node) => (
              <article class="node-card" data-node-id={node.id}>
                <div class="node-head">
                  <div>
                    <span class:list={["status-pill", node.status]} data-node-status>{node.status}</span>
                    <h3>{node.label}</h3>
                    <p>{node.role} · {node.host}</p>
                  </div>
                  <span>{node.publicWorkloads.length ? `${node.publicWorkloads.length} public workload${node.publicWorkloads.length === 1 ? "" : "s"}` : "no public hosting"}</span>
                </div>
                <div class="surface-grid">
                  {node.agents.map((agent) => (
                    <div data-service-label={agent.name}>
                      <span class:list={["mini-state", agent.status]}>{agent.status}</span>
                      <strong>{agent.name}</strong>
                      <p>{agent.detail}</p>
                    </div>
                  ))}
                  {node.privateAccess.map((access) => (
                    <div data-service-label={access.name}>
                      <span class:list={["mini-state", access.status]}>{access.status}</span>
                      <strong>{access.name}</strong>
                      <p>{access.detail}</p>
                    </div>
                  ))}
                </div>
                <ul>
                  {node.notes.map((note) => <li>{note}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="content-grid">
        <section class="panel cron-panel" aria-labelledby="cron-title">
          <div class="panel-head">
            <div>
              <p class="eyebrow">Schedules</p>
              <h2 id="cron-title">Codex app schedules now running as cron</h2>
            </div>
            <code>fleet-ops/automation/codex-cron/jobs.tsv</code>
          </div>

          <div class="jobs">
            {
              cronJobs.map((job) => (
                <article class="job-card">
                  <div class="job-head">
                    <div>
                      <h3>{job.name}</h3>
                      <code>{job.id}</code>
                    </div>
                    <span class:list={["job-state", job.enabled ? "on" : "off"]}>
                      {job.enabled ? "active" : "off"}
                    </span>
                  </div>
                  <dl>
                    <div>
                      <dt>When</dt>
                      <dd>{job.nextHint}</dd>
                    </div>
                    <div>
                      <dt>Cron</dt>
                      <dd><code>{job.cron}</code></dd>
                    </div>
                    <div>
                      <dt>Model</dt>
                      <dd>{job.model} / {job.effort}</dd>
                    </div>
                    <div>
                      <dt>Lock</dt>
                      <dd>{job.lockMinutes} min</dd>
                    </div>
                  </dl>
                  <details>
                    <summary>Prompt summary</summary>
                    <p>{job.promptSummary}</p>
                  </details>
                </article>
              ))
            }
          </div>
        </section>

        <aside class="side-stack">
          <section class="panel wifi-panel" aria-labelledby="wifi-title">
            <div class="panel-head compact">
              <div>
                <p class="eyebrow">Fleet product</p>
                <h2 id="wifi-title">Wi-Fi Watch</h2>
              </div>
              <span class:list={["health", wifi.health]}>{wifi.health}</span>
            </div>
            <div class="wifi-number">
              <strong>{wifi.latestMbps ?? "-"}</strong>
              <span>latest Mbps</span>
            </div>
            <div class="sparkline" aria-label="Recent Wi-Fi speed samples">
              {
                wifi.sparkline.map((value) => (
                  <i style={`height: ${Math.max(10, Math.round((value / wifiMax) * 100))}%`} />
                ))
              }
            </div>
            <dl class="facts">
              <div>
                <dt>Average probe</dt>
                <dd>{wifi.averageMbps ?? "-"} Mbps</dd>
              </div>
              <div>
                <dt>Events</dt>
                <dd>{wifi.eventCount}</dd>
              </div>
              <div>
                <dt>Incidents, 24h</dt>
                <dd>{wifi.incidents24h}</dd>
              </div>
              <div>
                <dt>Latest sample</dt>
                <dd>{formatDate(wifi.latestSampleAt)}</dd>
              </div>
            </dl>
            <p class="note">
              Linked from <code>{wifi.productPath}</code>. Local network identifiers and raw diagnostics stay private.
            </p>
          </section>

          <section class="panel commands-panel" aria-labelledby="commands-title">
            <div class="panel-head compact">
              <div>
                <p class="eyebrow">Runbook</p>
                <h2 id="commands-title">Private control boundary</h2>
              </div>
            </div>
            <ul>
              <li><strong>Telegram</strong><span>OpenClaw operator with optional Hermes backup lane</span></li>
              <li><strong>Tailscale SSH</strong><span>durable phone-to-machine terminal access</span></li>
              <li><strong>Cloudflare Access</strong><span>required before any private operational view is published</span></li>
              <li><strong>Public dashboard</strong><span>sanitized health only; no tokens, terminal links, IPs, or controls</span></li>
            </ul>
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>

<script is:inline>
  const formatHeartbeat = (value) =>
    new Intl.DateTimeFormat("en", {
      dateStyle: "medium",
      timeStyle: "medium",
      timeZone: "Asia/Kolkata"
    }).format(new Date(value));

  const setState = (element, state) => {
    if (!element) return;
    element.textContent = state;
    element.className = element.className
      .split(" ")
      .filter((name) => !["online", "degraded", "offline", "running", "stopped", "needs-setup"].includes(name))
      .concat(state)
      .join(" ");
  };

  async function refreshHeartbeat() {
    const at = document.querySelector("[data-heartbeat-at]");
    const state = document.querySelector("[data-heartbeat-state]");
    try {
      const response = await fetch("/api/runtime", { cache: "no-store" });
      if (!response.ok) throw new Error("heartbeat unavailable");
      const heartbeat = await response.json();
      const ageMs = Date.now() - Date.parse(heartbeat.generatedAt);
      const nodeState = ageMs > 180000 ? "offline" : heartbeat.node.status;
      at.textContent = `Last heartbeat ${formatHeartbeat(heartbeat.generatedAt)}`;
      state.textContent = `Primary machine ${nodeState}`;
      const notificationState = document.querySelector("[data-notification-state]");
      if (notificationState && heartbeat.notifications) {
        const pending = Number(heartbeat.notifications.pending || 0);
        const critical = Number(heartbeat.notifications.critical || 0);
        const blocked = Number(heartbeat.notifications.blocked || 0);
        notificationState.textContent = critical
          ? `Notifications ${critical} critical / ${pending} pending`
          : blocked
            ? `Notifications ${blocked} blocked / ${pending} pending`
            : `Notifications healthy / ${pending} pending`;
      }
      const taskState = document.querySelector("[data-task-state]");
      if (taskState && heartbeat.tasks) {
        const active = Number(heartbeat.tasks.running || 0) + Number(heartbeat.tasks.queued || 0);
        taskState.textContent = active
          ? `Agent tasks ${active} active / latest ${heartbeat.tasks.recentStatus}`
          : `Agent tasks idle / latest ${heartbeat.tasks.recentStatus}`;
      }

      const node = document.querySelector(`[data-node-id="${heartbeat.node.id}"]`);
      setState(node?.querySelector("[data-node-status]"), nodeState);

      for (const service of heartbeat.node.services || []) {
        const surface = [...document.querySelectorAll("[data-service-label]")]
          .find((element) => element.dataset.serviceLabel === service.label ||
            (service.id === "console" && element.dataset.serviceLabel === "Fleet Ops console") ||
            (service.id === "tailscale" && element.dataset.serviceLabel === "Tailscale SSH"));
        setState(surface?.querySelector(".mini-state"), service.status);
      }

      for (const domain of heartbeat.domains || []) {
        const row = document.querySelector(`[data-domain="${domain.domain}"]`);
        if (!row) continue;
        const rating = row.querySelector("[data-domain-rating]");
        const score = row.querySelector("[data-domain-score]");
        const lcp = row.querySelector("[data-domain-lcp]");
        const cls = row.querySelector("[data-domain-cls]");
        const updated = row.querySelector("[data-domain-updated]");
        if (rating) rating.textContent = String(domain.domainRating ?? "-");
        if (score) {
          score.textContent = domain.performanceScore === null ? "Pending" : String(Math.round(domain.performanceScore));
          score.className = domain.performanceScore >= 90 ? "good" : domain.performanceScore >= 50 ? "warn" : "bad";
        }
        if (lcp) lcp.textContent = domain.lcpMs === null ? "Pending" : `${(domain.lcpMs / 1000).toFixed(2)}s`;
        if (cls) cls.textContent = domain.cls === null ? "Pending" : Number(domain.cls).toFixed(3);
        const updatedAt = domain.psiUpdatedAt || domain.domainRatingUpdatedAt;
        if (updated) updated.textContent = updatedAt ? formatHeartbeat(updatedAt) : "Pending";
      }
    } catch {
      at.textContent = "Live heartbeat unavailable";
      state.textContent = "Static project snapshot remains available";
      const notificationState = document.querySelector("[data-notification-state]");
      if (notificationState) notificationState.textContent = "Notification state unavailable";
      const taskState = document.querySelector("[data-task-state]");
      if (taskState) taskState.textContent = "Agent task state unavailable";
    }
  }

  refreshHeartbeat();
  window.setInterval(refreshHeartbeat, 30000);
</script>

<style>
  :root {
    color-scheme: dark;
    --bg: #090b0c;
    --panel: #101416;
    --panel-strong: #151b1d;
    --line: #2b302d;
    --text: #f3f6f4;
    --muted: #a6aea9;
    --green: #91e49e;
    --cyan: #79dcc8;
    --yellow: #f2c14e;
    --red: #ff8e8e;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.45;
  }

  code,
  pre {
    font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
  }

  code {
    color: var(--cyan);
    overflow-wrap: anywhere;
  }

  .shell {
    width: min(1240px, 100%);
    margin: 0 auto;
    padding: 24px;
  }

  .topbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    min-height: 148px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow,
  .label {
    margin: 0 0 6px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0;
    max-width: 840px;
    font-size: 52px;
    line-height: 1;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 0;
    font-size: 22px;
  }

  h3 {
    margin-bottom: 4px;
    font-size: 16px;
  }

  .status-pill,
  .job-state,
  .health {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    border: 1px solid var(--line);
    border-radius: 0;
    padding: 4px 10px;
    color: var(--muted);
    background: #111518;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .topnav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .topnav a {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid var(--line);
    border-radius: 0;
    padding: 10px 14px;
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }

  .topnav a.active,
  .topnav a:hover {
    color: var(--text);
    border-color: var(--cyan);
  }

  .lane-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(220px, 1fr));
    margin-bottom: 16px;
    overflow-x: auto;
    border-block: 1px solid var(--line);
  }

  .lane-grid a {
    display: grid;
    min-height: 112px;
    align-content: center;
    gap: 4px;
    padding: 16px;
    border-right: 1px solid var(--line);
    color: var(--text);
    text-decoration: none;
    transition: background 140ms ease;
  }

  .lane-grid a:last-child {
    border-right: 0;
  }

  .lane-grid a:hover {
    background: rgba(118, 215, 196, 0.07);
  }

  .lane-grid span,
  .lane-grid small {
    color: var(--muted);
  }

  .lane-grid span {
    font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
  }

  .lane-grid strong {
    font-size: 18px;
  }

  .lane-grid small {
    font-size: 12px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .summary-card,
  .panel,
  .job-card {
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--panel);
  }

  .summary-card {
    min-height: 142px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .summary-card.primary {
    background: var(--panel-strong);
  }

  .summary-card strong {
    display: block;
    font-size: 38px;
    line-height: 1;
    text-transform: capitalize;
  }

  .summary-card span,
  .note,
  .commands-panel span {
    color: var(--muted);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 16px;
    align-items: start;
  }

  .update-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--muted);
  }

  .update-panel strong {
    color: var(--text);
  }

  .panel {
    padding: 16px;
  }

  .hosting-panel {
    margin-bottom: 16px;
  }

  .node-panel {
    margin-bottom: 16px;
  }

  .project-panel {
    margin-bottom: 16px;
  }

  .domain-panel {
    margin-bottom: 16px;
  }

  .domain-table {
    border-top: 1px solid var(--line);
  }

  .domain-row {
    display: grid;
    grid-template-columns: minmax(180px, 1.3fr) repeat(4, minmax(90px, .65fr)) minmax(160px, 1fr);
    gap: 14px;
    align-items: center;
    min-height: 58px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
  }

  .domain-row a {
    color: var(--cyan);
  }

  .domain-row time,
  .domain-row span {
    color: var(--muted);
  }

  .domain-head {
    min-height: 40px;
    color: var(--muted);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .domain-row .good { color: var(--green); }
  .domain-row .warn { color: var(--yellow); }
  .domain-row .bad { color: var(--red); }

  .project-directory {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .project-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 18px;
    min-height: 170px;
    padding: 16px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    color: var(--text);
    text-decoration: none;
  }

  .project-item:hover {
    background: rgba(121, 220, 200, 0.04);
  }

  .project-title h3 {
    margin: 10px 0 5px;
    font-size: 19px;
  }

