---
import { getFleetProjects, getSnapshotInfo } from "../lib/fleet-data";

const projects = getFleetProjects();
const snapshot = getSnapshotInfo();
const activeProjects = projects
  .filter((project) => project.openTasks.length > 0)
  .sort((left, right) => right.highPriorityTasks - left.highPriorityTasks || right.openTasks.length - left.openTasks.length);
const tasks = activeProjects
  .flatMap((project) => project.openTasks.map((task) => ({ ...task, projectTitle: project.title })))
  .sort((left, right) => Number(right.priority === "high") - Number(left.priority === "high") || Number(right.blocked) - Number(left.blocked));
const blockedTasks = tasks.filter((task) => task.blocked).length;
const highPriorityTasks = tasks.filter((task) => task.priority === "high").length;
const formatDate = (value: string | null) => value
  ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short", timeZone: "Asia/Kolkata" }).format(new Date(value))
  : "No recent update";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Build · Fleet Ops</title>
    <meta name="description" content="Current Fleet project execution queue and active work." />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div><p class="eyebrow">Fleet Ops / Build</p><h1>Execution queue</h1></div>
        <nav aria-label="Fleet console"><a href="/">Overview</a><a href="/projects">Projects</a><a class="active" href="/build">Build</a><a href="/marketing">Market</a><a href="https://swe-interview-prep.pages.dev/sources">Learn</a></nav>
      </header>

      <section class="summary" aria-label="Build summary">
        <div><span>Active projects</span><strong>{activeProjects.length}</strong><small>with open work</small></div>
        <div><span>Open tasks</span><strong>{tasks.length}</strong><small>across the fleet</small></div>
        <div><span>High priority</span><strong>{highPriorityTasks}</strong><small>need focused execution</small></div>
        <div><span>Blocked</span><strong>{blockedTasks}</strong><small>waiting for input</small></div>
      </section>

      <section class="band">
        <div class="section-head"><div><p class="eyebrow">Projects</p><h2>Work in progress</h2></div><span>Snapshot {formatDate(snapshot.generatedAt)}</span></div>
        <div class="project-list">
          {activeProjects.map((project) => (
            <a class="project" href={`/projects/${project.slug}`}>
              <div><span class:list={["state", project.state]}>{project.stateLabel}</span><h3>{project.title}</h3><p>{project.desc}</p></div>
              <dl>
                <div><dt>Open</dt><dd>{project.openTasks.length}</dd></div>
                <div><dt>High</dt><dd>{project.highPriorityTasks}</dd></div>
                <div><dt>Blocked</dt><dd>{project.blockedTasks}</dd></div>
                <div><dt>Updated</dt><dd>{formatDate(project.updatedAt)}</dd></div>
              </dl>
            </a>
          ))}
        </div>
      </section>

      <section class="band">
        <div class="section-head"><div><p class="eyebrow">Tasks</p><h2>Next work</h2></div><span>Top {Math.min(tasks.length, 12)} of {tasks.length} open</span></div>
        <div class="task-list">
          {tasks.slice(0, 12).map((task) => (
            <article class="task">
              <div><span class:list={["priority", task.priority]}>{task.priority}</span><strong>{task.projectTitle}</strong></div>
              <h3>{task.title}</h3>
              <p>{task.status}{task.size ? ` · ${task.size}` : ""}{task.blocked ? " · blocked on input" : ""}</p>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root{color-scheme:dark;--bg:#090b0c;--surface:#101416;--line:#2b302d;--text:#f3f6f4;--muted:#a6aea9;--mint:#79dcc8;--yellow:#f2c14e;--red:#ff8e8e;--green:#91e49e}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,sans-serif;letter-spacing:0}.shell{width:min(1240px,100%);margin:auto;padding:24px}.topbar{min-height:150px;display:flex;align-items:flex-end;justify-content:space-between;gap:24px;border-bottom:1px solid var(--line);padding-bottom:24px}.eyebrow{margin:0 0 8px;color:var(--mint);font-size:12px;font-weight:800;text-transform:uppercase}h1,h2,h3,p{margin-top:0}h1{margin-bottom:0;font-size:52px;line-height:1}h2{margin-bottom:0;font-size:28px}nav{display:flex;gap:6px}nav a{color:var(--muted);text-decoration:none;border:1px solid var(--line);padding:10px 14px}nav a.active,nav a:hover{color:var(--text);border-color:var(--mint)}.summary{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--line)}.summary div{min-height:145px;padding:24px;border-right:1px solid var(--line);display:grid;align-content:center}.summary div:last-child{border-right:0}.summary span,.summary small,.section-head>span{color:var(--muted)}.summary strong{font-size:40px}.band{padding:44px 0;border-bottom:1px solid var(--line)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:24px}.project-list,.task-list{border-top:1px solid var(--line)}.project{display:grid;grid-template-columns:minmax(260px,1fr) 1fr;gap:28px;padding:20px 0;border-bottom:1px solid var(--line);color:var(--text);text-decoration:none}.project h3{margin:9px 0 5px;font-size:20px}.project p,.task p{margin-bottom:0;color:var(--muted)}dl{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:0;align-content:center}dt{color:var(--muted);font-size:10px;text-transform:uppercase}dd{margin:4px 0 0;font-weight:800}.state,.priority{display:inline-flex;width:max-content;border:1px solid var(--line);padding:4px 8px;font:800 10px ui-monospace,monospace;text-transform:uppercase}.state.steady{color:var(--green);border-color:#91e49e66}.state.active,.priority.medium{color:var(--mint);border-color:#79dcc866}.state.blocked,.state.local-changes,.priority.low{color:var(--yellow);border-color:#f2c14e66}.state.needs-attention,.priority.high{color:var(--red);border-color:#ff8e8e66}.task{display:grid;grid-template-columns:190px 1fr minmax(160px,.5fr);gap:20px;align-items:center;padding:18px 0;border-bottom:1px solid var(--line)}.task>div{display:grid;gap:8px}.task h3{margin:0;font-size:16px}.task p{text-align:right}@media(max-width:760px){.shell{padding:14px}.topbar,.section-head{display:grid}.topbar{min-height:170px}nav{overflow-x:auto}h1{font-size:40px}.summary{grid-template-columns:1fr 1fr}.summary div{min-height:115px;padding:16px}.summary div:nth-child(2){border-right:0}.project,.task{grid-template-columns:1fr;gap:14px}.project dl{grid-template-columns:1fr 1fr}.task p{text-align:left}}
</style>
