---
import { getFleetConnections, getFleetProjects, getSnapshotInfo } from "../../lib/fleet-data";

export function getStaticPaths() {
  return getFleetProjects().map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const snapshot = getSnapshotInfo();
const connections = getFleetConnections().filter((edge) => edge.from === project.slug || edge.to === project.slug);
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short", timeZone: "Asia/Kolkata" }).format(new Date(value))
    : "No data";
const updated = project.updatedAt ? formatDate(project.updatedAt) : "No recent task";
---

<!doctype html>
<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>{project.slug} · Fleet Project</title></head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div><p class="eyebrow">Project</p><h1>{project.slug}</h1></div>
        <nav class="topnav" aria-label="Fleet console"><a href="/">Overview</a><a href="/projects">Projects</a><a href="/connections">Connections</a></nav>
      </header>

      <section class="grid">
        <article class="panel hero">
          <div class="badges">
            <span class:list={["state", project.state]}>{project.stateLabel}</span>
            <span class:list={["hosting", project.hostingKind]}>{project.hostingLabel}</span>
          </div>
          <p>{project.desc}</p>
          <p class="muted">{project.hostingDetail}</p>
          <div class="links">
            {project.repoUrl && <a href={project.repoUrl}>Repository</a>}
            {project.homepage && <a href={project.homepage}>Homepage</a>}
          </div>
        </article>
        <article class="panel">
          <h2>State</h2>
          <dl>
            <div><dt>Lane</dt><dd>{project.lane}</dd></div>
            <div><dt>Tier</dt><dd>{project.tier}</dd></div>
            <div><dt>Hosting</dt><dd>{project.hostingLabel}</dd></div>
            <div><dt>Checkout</dt><dd>{project.localPath}</dd></div>
            <div><dt>Branch</dt><dd>{project.branch ?? "n/a"}</dd></div>
            <div><dt>Dirty files</dt><dd>{project.dirtyCount}</dd></div>
            <div><dt>Smoke</dt><dd>{project.smokeStatus} · {project.smokeFailures} failures</dd></div>
            <div><dt>Workflow</dt><dd>{project.workflowStatus}</dd></div>
            <div><dt>Tasks</dt><dd>{project.taskSummary}</dd></div>
            <div><dt>Last task update</dt><dd>{updated}</dd></div>
          </dl>
        </article>
      </section>

      <section class="panel freshness">
        <strong>Last updated {formatDate(snapshot.generatedAt)}</strong>
        <span>{snapshot.refreshCadence}</span>
        <span>Tasks {formatDate(snapshot.tasksSyncedAt)} · Smoke {formatDate(snapshot.smokeGeneratedAt)} · Audit {formatDate(snapshot.auditGeneratedAt)}</span>
      </section>

      <section class="grid">
        <article class="panel">
          <div class="panel-head"><h2>Source</h2><span>{project.checkedOut ? "local checkout present" : "catalog only"}</span></div>
          <dl>
            <div><dt>Canonical slug</dt><dd>{project.slug}</dd></div>
            <div><dt>Local folder</dt><dd>{project.localDir}</dd></div>
            <div><dt>Local path</dt><dd>{project.localPath}</dd></div>
            <div><dt>Repository</dt><dd>{project.repoUrl ? "linked" : "missing"}</dd></div>
          </dl>
        </article>
        <article class="panel">
          <div class="panel-head"><h2>Work mix</h2><span>{project.taskSummary}</span></div>
          <dl>
            <div><dt>Open</dt><dd>{project.openTasks.length}</dd></div>
            <div><dt>High priority</dt><dd>{project.highPriorityTasks}</dd></div>
            <div><dt>Blocked</dt><dd>{project.blockedTasks}</dd></div>
            <div><dt>Done</dt><dd>{project.doneTasks}</dd></div>
          </dl>
        </article>
      </section>

      <section class="panel">
        <div class="panel-head"><h2>Current work</h2><span>{project.openTasks.length} open · {project.blockedTasks} blocked · {project.doneTasks} done</span></div>
        <div class="tasks">
          {project.openTasks.length === 0 && <p class="muted">No open Symphony tasks are attached to this project.</p>}
          {
            project.openTasks.slice(0, 12).map((task) => (
              <article class="task">
                <span class:list={["priority", task.priority]}>{task.priority}</span>
                <h3>{task.title}</h3>
                <p>{task.status}{task.size ? ` · ${task.size}` : ""}{task.blocked ? " · blocked on user" : ""}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="panel">
        <div class="panel-head"><h2>Connections</h2><span>{connections.length} edges</span></div>
        <div class="connections">
          {connections.map((edge) => <article><strong>{edge.from} → {edge.to}</strong><span>{edge.type}</span><p>{edge.detail}</p></article>)}
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root{color-scheme:dark;--bg:#0f1110;--panel:#171a18;--line:#333a36;--text:#f4f6f8;--muted:#aab3bd;--green:#8ce99a;--cyan:#76d7c4;--yellow:#ffd166;--red:#ff8787}*{box-sizing:border-box}body{margin:0;background:linear-gradient(180deg,rgba(118,215,196,.08),transparent 320px),var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.45}.shell{width:min(1280px,100%);margin:0 auto;padding:24px}.topbar{display:flex;align-items:end;justify-content:space-between;gap:16px;min-height:128px;margin-bottom:16px;border-bottom:1px solid var(--line)}.eyebrow{margin:0 0 6px;color:var(--muted);font-size:12px;font-weight:800;text-transform:uppercase}h1{margin:0;font-size:clamp(42px,7vw,78px);line-height:.98;letter-spacing:0}h2,h3,p{margin-top:0}.topnav{display:flex;flex-wrap:wrap;justify-content:flex-end;gap:8px;margin-bottom:12px}.topnav a,.links a{display:inline-flex;align-items:center;min-height:32px;border:1px solid var(--line);border-radius:999px;padding:4px 12px;color:var(--muted);text-decoration:none;font-size:12px;font-weight:800;text-transform:uppercase}.grid{display:grid;grid-template-columns:1.1fr .9fr;gap:16px;margin-bottom:16px}.panel,.task,.connections article{border:1px solid var(--line);border-radius:8px;background:var(--panel);padding:16px}.hero p{margin:18px 0;color:var(--muted);font-size:20px}.hero .muted{font-size:15px}.badges,.links{display:flex;flex-wrap:wrap;gap:8px}.freshness{display:flex;flex-wrap:wrap;gap:10px 18px;margin-bottom:16px;color:var(--muted)}.freshness strong{color:var(--text)}dl{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin:0}dt,.muted,.panel-head span,.task p,.connections p{color:var(--muted)}dd{margin:2px 0 0;font-weight:800;overflow-wrap:anywhere}.panel-head{display:flex;justify-content:space-between;gap:16px;margin-bottom:14px}.tasks,.connections{display:grid;gap:10px}.task h3{margin:8px 0}.connections article{display:grid;gap:4px}.connections span{color:var(--cyan);font-weight:800}.state,.priority,.hosting{display:inline-flex;border:1px solid var(--line);border-radius:999px;padding:3px 9px;font-size:12px;font-weight:800;text-transform:uppercase}.state.needs-attention,.priority.high{color:var(--red);border-color:rgba(255,135,135,.5);background:rgba(255,135,135,.08)}.state.active,.priority.medium,.hosting.machine{color:var(--cyan);border-color:rgba(118,215,196,.5);background:rgba(118,215,196,.08)}.state.blocked,.state.local-changes,.priority.low,.hosting.external,.hosting.local{color:var(--yellow);border-color:rgba(255,209,102,.5);background:rgba(255,209,102,.08)}.state.steady,.hosting.cloudflare{color:var(--green);border-color:rgba(140,233,154,.5);background:rgba(140,233,154,.08)}.hosting.unknown{color:var(--muted)}@media(max-width:760px){.shell{padding:14px}.topbar,.grid,.panel-head{display:grid}.topnav{justify-content:stretch}.topnav a{justify-content:center}.grid,dl{grid-template-columns:1fr}.hero p{font-size:17px}}
</style>
