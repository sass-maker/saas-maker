---
import { getFleetProjects, getSnapshotInfo } from "../../lib/fleet-data";

export function getStaticPaths() {
  return getFleetProjects().map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const snapshot = getSnapshotInfo();
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", { dateStyle: "medium", timeStyle: "short", timeZone: "Asia/Kolkata" }).format(new Date(value))
    : "No data";
const updated = project.updatedAt ? formatDate(project.updatedAt) : "No recent task";
---

<!doctype html>
<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>{project.title} · Fleet Project</title></head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div><p class="eyebrow">Project</p><h1>{project.title}</h1></div>
        <nav class="topnav" aria-label="Fleet console"><a class="active" href="/">Overview</a><a href="/build">Build</a><a href="/marketing">Market</a><a href="https://swe-interview-prep.pages.dev/sources">Learn</a></nav>
      </header>

      <section class="grid">
        <article class="panel hero">
          <div class="badges">
            <span class:list={["state", project.state]}>{project.stateLabel}</span>
            <span class:list={["hosting", project.hostingKind]}>{project.hostingLabel}</span>
          </div>
          <p>{project.desc}</p>
          <p class="muted">{project.hostingDetail}</p>
          <div class="links">
            {project.repoUrl && <a href={project.repoUrl}>Repository</a>}
            {project.homepage && <a href={project.homepage}>Homepage</a>}
          </div>
        </article>
        <article class="panel">
          <h2>State</h2>
          <dl>
            <div><dt>Lane</dt><dd>{project.lane}</dd></div>
            <div><dt>Tier</dt><dd>{project.tier}</dd></div>
            <div><dt>Hosting</dt><dd>{project.hostingLabel}</dd></div>
            <div><dt>Checkout</dt><dd>{project.localPath}</dd></div>
            <div><dt>Branch</dt><dd>{project.branch ?? "n/a"}</dd></div>
            <div><dt>Dirty files</dt><dd>{project.dirtyCount}</dd></div>
            <div><dt>Smoke</dt><dd>{project.smokeStatus} · {project.smokeFailures} failures</dd></div>
            <div><dt>Workflow</dt><dd>{project.workflowStatus}</dd></div>
            <div><dt>Tasks</dt><dd>{project.taskSummary}</dd></div>
            <div><dt>Last task update</dt><dd>{updated}</dd></div>
          </dl>
        </article>
      </section>

      <section class="panel freshness">
        <strong>Last updated {formatDate(snapshot.generatedAt)}</strong>
        <span>{snapshot.refreshCadence}</span>
        <span>Tasks {formatDate(snapshot.tasksSyncedAt)} · Smoke {formatDate(snapshot.smokeGeneratedAt)} · Audit {formatDate(snapshot.auditGeneratedAt)}</span>
      </section>

      <section class="grid">
        <article class="panel">
          <div class="panel-head"><h2>Source</h2><span>{project.checkedOut ? "local checkout present" : "catalog only"}</span></div>
          <dl>
            <div><dt>Canonical slug</dt><dd>{project.slug}</dd></div>
            <div><dt>Local folder</dt><dd>{project.localDir}</dd></div>
            <div><dt>Local path</dt><dd>{project.localPath}</dd></div>
            <div><dt>Repository</dt><dd>{project.repoUrl ? "linked" : "missing"}</dd></div>
          </dl>
        </article>
        <article class="panel">
          <div class="panel-head"><h2>Work mix</h2><span>{project.taskSummary}</span></div>
          <dl>
            <div><dt>Open</dt><dd>{project.openTasks.length}</dd></div>
            <div><dt>High priority</dt><dd>{project.highPriorityTasks}</dd></div>
            <div><dt>Blocked</dt><dd>{project.blockedTasks}</dd></div>
            <div><dt>Done</dt><dd>{project.doneTasks}</dd></div>
          </dl>
        </article>
      </section>

      <section class="panel">
        <div class="panel-head"><h2>Current work</h2><span>{project.openTasks.length} open · {project.blockedTasks} blocked · {project.doneTasks} done</span></div>
        <div class="tasks">
          {project.openTasks.length === 0 && <p class="muted">No open Symphony tasks are attached to this project.</p>}
          {
            project.openTasks.slice(0, 12).map((task) => (
              <article class="task">
                <span class:list={["priority", task.priority]}>{task.priority}</span>
                <h3>{task.title}</h3>
                <p>{task.status}{task.size ? ` · ${task.size}` : ""}{task.blocked ? " · blocked on user" : ""}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root{color-scheme:dark;--bg:#090b0c;--panel:#101416;--line:#2b302d;--text:#f3f6f4;--muted:#a6aea9;--green:#91e49e;--cyan:#79dcc8;--yellow:#f2c14e;--red:#ff8e8e}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.45}.shell{width:min(1240px,100%);margin:0 auto;padding:24px}.topbar{display:flex;align-items:end;justify-content:space-between;gap:16px;min-height:150px;padding-bottom:24px;border-bottom:1px solid var(--line)}.eyebrow{margin:0 0 8px;color:var(--cyan);font-size:12px;font-weight:800;text-transform:uppercase}h1{margin:0;font-size:52px;line-height:1;letter-spacing:0}h2,h3,p{margin-top:0}.topnav{display:flex;flex-wrap:wrap;justify-content:flex-end;gap:6px}.topnav a,.links a{display:inline-flex;align-items:center;border:1px solid var(--line);padding:10px 14px;color:var(--muted);text-decoration:none;font-size:14px;font-weight:600}.topnav a.active,.topnav a:hover,.links a:hover{color:var(--text);border-color:var(--cyan)}.grid{display:grid;grid-template-columns:1.1fr .9fr;gap:16px;margin:32px 0 16px}.panel,.task{border:1px solid var(--line);background:var(--panel);padding:18px}.hero p{margin:18px 0;color:var(--muted);font-size:20px}.hero .muted{font-size:15px}.badges,.links{display:flex;flex-wrap:wrap;gap:8px}.freshness{display:flex;flex-wrap:wrap;gap:10px 18px;margin-bottom:16px;color:var(--muted)}.freshness strong{color:var(--text)}dl{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin:0}dt,.muted,.panel-head span,.task p{color:var(--muted)}dd{margin:2px 0 0;font-weight:800;overflow-wrap:anywhere}.panel-head{display:flex;justify-content:space-between;gap:16px;margin-bottom:14px}.tasks{display:grid;gap:10px}.task h3{margin:8px 0}.state,.priority,.hosting{display:inline-flex;border:1px solid var(--line);padding:4px 8px;font:800 10px ui-monospace,monospace;text-transform:uppercase}.state.needs-attention,.priority.high{color:var(--red);border-color:rgba(255,142,142,.5);background:rgba(255,142,142,.08)}.state.active,.priority.medium,.hosting.machine{color:var(--cyan);border-color:rgba(121,220,200,.5);background:rgba(121,220,200,.08)}.state.blocked,.state.local-changes,.priority.low,.hosting.external,.hosting.local{color:var(--yellow);border-color:rgba(242,193,78,.5);background:rgba(242,193,78,.08)}.state.steady,.hosting.cloudflare{color:var(--green);border-color:rgba(145,228,158,.5);background:rgba(145,228,158,.08)}.hosting.unknown{color:var(--muted)}@media(max-width:760px){.shell{padding:14px}.topbar,.grid,.panel-head{display:grid}.topbar{min-height:170px}h1{font-size:40px}.topnav{justify-content:stretch}.topnav a{justify-content:center}.grid,dl{grid-template-columns:1fr}.hero p{font-size:17px}}
</style>
<style>
  @media(max-width:760px){.topbar .topnav{display:grid;grid-template-columns:repeat(4,minmax(0,1fr))}.topnav a{padding-inline:8px}}
</style>
