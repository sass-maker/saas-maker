{
  "expo": {
    "name": "Mobile Dev Cockpit",
    "slug": "mobile-dev-cockpit",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "mobiledevcockpit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "dev.sarthak.mobiledevcockpit",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Mobile Dev Cockpit uses the microphone only while you record a voice draft for an agent instruction.",
        "NSSpeechRecognitionUsageDescription": "Mobile Dev Cockpit transcribes your voice into an editable agent instruction using Apple Speech."
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050A14"
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "./plugins/with-ios-scene-lifecycle"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "platforms": ["ios", "web"]
  }
}
