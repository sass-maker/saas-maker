---
import skillsCatalog from '../../../../catalog/generated/skills.json';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const skills = skillsCatalog.skills;
const sourceRoot = 'https://github.com/sass-maker/saas-maker/blob/main/';
const groups = [
  { id: 'operate', name: 'Operate', match: /fleet|deploy|workspace|mobile-task|spec-driven|token-budget/ },
  { id: 'inspect', name: 'Inspect', match: /audit|health|seo|agent-ready|psi|geo/ },
  { id: 'delegate', name: 'Delegate', match: /call-/ },
  { id: 'learn', name: 'Learn', match: /learning|research|evidence/ },
  { id: 'create', name: 'Create', match: /name-domains|fleet-init/ },
];
function groupFor(id: string) { return groups.find((group) => group.match.test(id))?.id ?? 'operate'; }
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Foundry Skills',
  numberOfItems: skills.length,
  itemListElement: skills.map((skill, index) => ({
    '@type': 'ListItem', position: index + 1,
    item: { '@type': 'SoftwareSourceCode', name: skill.name, description: skill.description, url: `${sourceRoot}${skill.path}` },
  })),
};
---
<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <header class="shell nav">
    <a class="brand" href="/" aria-label="Foundry Skills home"><span>F</span> Foundry Skills</a>
    <nav aria-label="Foundry surfaces">
      <a href="https://sassmaker.com">Directory</a>
      <a href="https://packages.sassmaker.com">Packages</a>
      <a href="https://github.com/sass-maker/saas-maker">Source</a>
    </nav>
  </header>

  <main class="shell">
    <section class="hero">
      <div>
        <p class="eyebrow">CONTROL PLANE / CAPABILITY INDEX</p>
        <h1>Small, inspectable skills for a large product fleet.</h1>
        <p class="lede">One canonical catalog for the workflows that build, market, learn from, observe, and control Foundry products. Every entry links to its versioned source.</p>
      </div>
      <div class="summary" aria-label="Catalog summary">
        <strong>{skills.length}</strong><span>tracked skills</span>
        <strong>5</strong><span>operating pillars</span>
        <strong>1</strong><span>source of truth</span>
      </div>
    </section>

    <section class="toolbar" aria-label="Skill filters">
      <label><span class="sr-only">Search skills</span><input id="skill-search" type="search" placeholder="Search skills and capabilities…" autocomplete="off" /></label>
      <div class="filters" role="group" aria-label="Filter by capability">
        <button class="active" type="button" data-filter="all">All</button>
        {groups.map((group) => <button type="button" data-filter={group.id}>{group.name}</button>)}
      </div>
    </section>

    <section aria-labelledby="catalog-title">
      <div class="section-head"><div><p class="eyebrow">PUBLIC CATALOG</p><h2 id="catalog-title">Capabilities</h2></div><p id="result-count" aria-live="polite">{skills.length} skills</p></div>
      <div class="grid" id="skill-grid">
        {skills.map((skill) => (
          <article class="card" data-skill data-group={groupFor(skill.id)} data-search={`${skill.name} ${skill.description} ${skill.id}`.toLowerCase()}>
            <div class="card-top"><span class="status"><i></i>{skill.state}</span><span class="group">{groups.find((group) => group.id === groupFor(skill.id))?.name}</span></div>
            <h3>{skill.name}</h3>
            <p>{skill.description}</p>
            <a href={`${sourceRoot}${skill.path}`} target="_blank" rel="noopener noreferrer">Read SKILL.md <span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
      <p class="empty" id="empty-state" hidden>No skills match this filter.</p>
    </section>
  </main>
  <footer class="shell"><p>Generated from <code>catalog/foundry.json</code>. Configuration is not proof of live execution.</p><p>Build · Market · Learn · Visibility · Control</p></footer>

  <script is:inline>
    const input = document.querySelector('#skill-search');
    const cards = [...document.querySelectorAll('[data-skill]')];
    const buttons = [...document.querySelectorAll('[data-filter]')];
    const count = document.querySelector('#result-count');
    const empty = document.querySelector('#empty-state');
    let filter = 'all';
    function render() {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const show = (filter === 'all' || card.dataset.group === filter) && card.dataset.search.includes(query);
        card.hidden = !show;
        if (show) visible += 1;
      }
      count.textContent = `${visible} ${visible === 1 ? 'skill' : 'skills'}`;
      empty.hidden = visible !== 0;
    }
    input.addEventListener('input', render);
    for (const button of buttons) button.addEventListener('click', () => {
      filter = button.dataset.filter;
      for (const candidate of buttons) candidate.classList.toggle('active', candidate === button);
      render();
    });
  </script>
</Layout>
