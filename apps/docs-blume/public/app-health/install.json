{
  "schema_version": "app-health.install.v1",
  "name": "SaaS Maker App Health",
  "release_status": "unreleased",
  "install_commands_active": false,
  "dashboard": "https://app.sassmaker.com/fleet/app-health",
  "ingest": "https://api.sassmaker.com/v1/performance/spans",
  "required_environment": ["SAASMAKER_API_KEY"],
  "project_identity": "derived-from-api-key",
  "runtimes": {
    "node": {
      "minimum": "20",
      "package": "@saas-maker/sdk",
      "minimum_package_version": "0.4.0",
      "install": "npm install @saas-maker/sdk@^0.4.0",
      "import": "createAppHealth",
      "middleware": ["Express 4+ compatible"],
      "guide": "https://packages.sassmaker.com/sdk/app-health-node.md"
    },
    "go": {
      "minimum": "1.22 with WithRouteResolver; 1.23 for automatic ServeMux discovery",
      "module": "github.com/sass-maker/saas-maker/packages/app-health-go",
      "install": "go get github.com/sass-maker/saas-maker/packages/app-health-go@latest",
      "middleware": [
        "net/http",
        "Go 1.23+ ServeMux Request.Pattern",
        "Go 1.22 route resolver required for non-root routes"
      ],
      "guide": "https://packages.sassmaker.com/sdk/app-health-go.md"
    }
  },
  "collected_fields": [
    "method",
    "normalized route template",
    "status class",
    "duration",
    "observed timestamp",
    "runtime source",
    "optional release"
  ],
  "delivery_envelope": [
    "schema version",
    "surface",
    "environment",
    "generated idempotency key",
    "generated trace id",
    "sampling rate",
    "empty operations list",
    "X-Project-Key authentication header"
  ],
  "never_collected": [
    "application-request credentials",
    "application-request headers",
    "cookies",
    "query values",
    "request body",
    "response body",
    "concrete path parameters",
    "user identity",
    "logs",
    "stack traces"
  ],
  "verification": [
    "Start the instrumented service with SAASMAKER_API_KEY set.",
    "Request a static and a dynamic endpoint.",
    "Open the private App Health dashboard and select Last hour.",
    "Confirm the dynamic route is templated and contains no query or identifier values."
  ]
}
