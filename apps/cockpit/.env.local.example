# Auth.js (required)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# API base URL (Foundry Workers API)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Public site URL (used to generate public board / roadmap links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SaaS Maker analytics API key (for cockpit self-analytics)
NEXT_PUBLIC_SAASMAKER_API_KEY=

# Optional: allow fleet scanning in production (leave unset to restrict to local only)
ALLOW_FLEET_SCAN=
