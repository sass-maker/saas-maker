# better-auth (required)
BETTER_AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# API base URL (Foundry Workers API)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Public site URL (used to generate public board / roadmap links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SaaS Maker analytics API key (for cockpit self-analytics)
NEXT_PUBLIC_SAASMAKER_API_KEY=

# Optional: allow fleet scanning in production (leave unset to restrict to local only)
ALLOW_FLEET_SCAN=

# PostHog Personal API Key + Project ID — used for fleet error feed (server-side only)
# Get from: https://us.posthog.com/settings/user-api-keys
POSTHOG_PERSONAL_API_KEY=
# Get from: https://us.posthog.com/settings/project
POSTHOG_PROJECT_ID=
