# Fleet web stack standard — HTML cache directives.
# Static Astro HTML is served from Cloudflare Pages; CF edge keeps the HTML
# warm via s-maxage and SWR, the browser only caches for an hour so users
# get fresh content soon after a redeploy.

/
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

/*.html
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800
