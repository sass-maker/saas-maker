---
import { PACKAGE_DOCS_URL } from '../data/links';

const GITHUB_URL = 'https://github.com/sass-maker/saas-maker';
const OWNER_URL = 'https://sarthakagrawal.dev';
---
<footer class="footer">
  <div class="footer-brand">
    <span class="brand-mark sm">
      <span class="brand-mark-glyph">S</span>
    </span>
    <span>SaaS Maker · a product directory by <a href={OWNER_URL} target="_blank" rel="noopener noreferrer">Sarthak Agrawal</a></span>
  </div>
  <div class="footer-links">
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href={PACKAGE_DOCS_URL} target="_blank" rel="noopener noreferrer">Packages</a>
    <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">Source</a>
  </div>
  <p class="footer-tagline">
    Products keep their own domains, repositories, and release boundaries.
  </p>
  <span class="footer-copy">
    <span class="footer-sigil">S</span>
    MMXXIV-present · MIT
  </span>
</footer>
