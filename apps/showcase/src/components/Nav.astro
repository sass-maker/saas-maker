---
import { PACKAGE_DOCS_URL } from '../data/links';

const GITHUB_URL = 'https://github.com/sass-maker/saas-maker';
const DASHBOARD_URL = 'https://app.sassmaker.com';
---
<nav class="nav">
  <a href="/" class="brand">
    <span class="brand-mark">
      <span class="brand-mark-glyph">S</span>
    </span>
    <span class="brand-stack">
      <span class="brand-name">SaaS Maker</span>
      <span class="brand-meta">Est. <em>MMXXIV</em> · sarthak</span>
    </span>
  </a>
  <div class="nav-links">
    <a href="#fleet">Products</a>
    <a href="#spec">Feedback</a>
    <a href={PACKAGE_DOCS_URL} target="_blank" rel="noopener noreferrer">Packages</a>
    <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">Source</a>
  </div>
  <div class="nav-actions">
    <a href={DASHBOARD_URL} class="btn btn-primary">Feedback inbox →</a>
  </div>
</nav>
