---
import { CORE, ACTIVE, PROJECT_COUNT } from '../data/projects';
---
<section class="section" id="fleet">
  <div class="section-head">
    <div class="section-marker">
      <span class="section-num">§ 01</span>
      <span class="section-rule"></span>
      <span class="section-kw">The Product</span>
    </div>
    <h2 class="section-title">
      {PROJECT_COUNT} <em class="italic">connected</em> repositories,
      <br />
      one shared <em class="italic">operating layer</em>.
    </h2>
    <p class="section-lede">
      SaaS Maker is the core product. The supporting repositories below extend
      its model access, search, media, and performance workflows.
    </p>
  </div>

  <div class="bento">
    {CORE.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class={`card card-${p.size}`}
        style={`--accent: ${p.color}; --delay: ${i * 70}ms`}
      >
        <div class="card-cover">
          <span class="card-cover-glow"></span>
          <span class="card-cover-grid"></span>
          <span class="card-monogram">{p.initials}</span>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="card-num">№ {p.n}</span>
            <span class="card-tag">{p.tag}</span>
          </div>
          <h3 class="card-title">{p.name}</h3>
          <p class="card-desc">{p.desc}</p>
          <span class="card-cta">
            <span>View repository</span>
            <span class="card-arrow">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="active">
    <div class="active-head">
      <span class="section-num">§ 01.02</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Supporting repositories</span>
      <span class="active-count">{ACTIVE.length} support</span>
    </div>
    <ul class="active-grid">
      {ACTIVE.map((p) => (
        <li>
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mini"
            style={`--accent: ${p.color}`}
          >
            <span class="mini-dot"></span>
            <span class="mini-name">{p.name}</span>
            <span class="mini-desc">{p.desc}</span>
            <span class="mini-arrow">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

</section>
