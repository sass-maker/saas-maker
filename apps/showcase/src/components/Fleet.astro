---
import { CORE, ACTIVE, PROJECT_COUNT } from '../data/projects';
import { REGISTRY_PRODUCTS } from '../data/registry';

const publicProducts = REGISTRY_PRODUCTS;
const spotlightIds = new Set(CORE.map((project) => project.href.replace('/p/', '')));
const spotlightProducts = publicProducts.filter((product) => spotlightIds.has(product.id));
---
<section class="section" id="fleet">
  <div class="section-head">
    <div class="section-marker">
      <span class="section-num">§ 01</span>
      <span class="section-rule"></span>
      <span class="section-kw">The Product</span>
    </div>
    <h2 class="section-title">
      {PROJECT_COUNT} <em class="italic">maintained</em> products,
      <br />
      one shared <em class="italic">operating layer</em>.
    </h2>
    <p class="section-lede">
      SaaS Maker is the broader directory and operating layer. The four
      spotlight products below are the public front door; the full catalog
      includes their supporting repositories and the rest of the fleet.
    </p>
  </div>

  <div class="product-directory" style="margin-bottom: 2.5rem">
    <div class="active-head" style="margin-bottom: 1rem">
      <span class="section-num">§ 01.00</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Spotlight products</span>
      <span class="active-count">{spotlightProducts.length} public anchors</span>
    </div>
    <p class="section-lede" style="margin-bottom: 1.25rem; max-width: 40rem">
      The concise product story: CodeVetter, Post-train LLM, HeyPace, and
      HiSignal. SaaS Maker is the directory for everything around them.
    </p>
    <ul class="product-directory-grid">
      {spotlightProducts.map((p) => (
        <li>
          <a href={`/p/${p.id}`} class="product-link" rel="noopener">
            <span class="product-link-name">{p.name}</span>
            <span class="product-link-host">{p.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>
            <span class="product-link-desc">{p.summary}</span>
            <span class="product-link-hub">View product page →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Crawlable dofollow product roots — hub link equity for the fleet. -->
  <div class="product-directory" id="products">
    <div class="active-head" style="margin-bottom: 1rem">
      <span class="section-num">§ 01.01</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Public product sites</span>
      <span class="active-count">{publicProducts.length} maintained</span>
    </div>
    <p class="section-lede" style="margin-bottom: 1.25rem; max-width: 40rem">
      Every maintained product in the public directory, with its canonical
      product or source URL, changelog, and roadmap.
    </p>
    <ul class="product-directory-grid">
      {publicProducts.map((p) => (
        <li>
          <a href={`/p/${p.id}`} class="product-link" rel="noopener">
            <span class="product-link-name">{p.name}</span>
            <span class="product-link-host">{p.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>
            {p.summary ? <span class="product-link-desc">{p.summary}</span> : null}
            <span class="product-link-hub">View product page →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="bento">
    {CORE.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class={`card card-${p.size}`}
        style={`--accent: ${p.color}; --delay: ${i * 70}ms`}
      >
        <div class="card-cover">
          <span class="card-cover-glow"></span>
          <span class="card-cover-grid"></span>
          <span class="card-monogram">{p.initials}</span>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="card-num">№ {p.n}</span>
            <span class="card-tag">{p.tag}</span>
          </div>
          <h3 class="card-title">{p.name}</h3>
          <p class="card-desc">{p.desc}</p>
          <span class="card-cta">
            <span>View repository</span>
            <span class="card-arrow">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="active">
    <div class="active-head">
      <span class="section-num">§ 01.02</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Supporting repositories</span>
      <span class="active-count">{ACTIVE.length} support</span>
    </div>
    <ul class="active-grid">
      {ACTIVE.map((p) => (
        <li>
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mini"
            style={`--accent: ${p.color}`}
          >
            <span class="mini-dot"></span>
            <span class="mini-name">{p.name}</span>
            <span class="mini-desc">{p.desc}</span>
            <span class="mini-arrow">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

</section>
