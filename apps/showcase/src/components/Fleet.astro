---
---
<section class="section" id="fleet">
  <div class="section-head">
    <div class="section-marker">
      <span class="section-num">§ 01</span>
      <span class="section-rule"></span>
      <span class="section-kw">The Fleet</span>
    </div>
    <h2 class="section-title">
      {PROJECT_COUNT} <em class="italic">distinct</em> projects,
      <br />
      one shared <em class="italic">operating layer</em>.
    </h2>
    <p class="section-lede">
      No mockups. No fake screenshots. Each card below is a real repository,
      color-coded by its place in the fleet, ordered by how much I&apos;m still actively shipping it.
    </p>
  </div>

  <div class="bento">
    {CORE.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class={`card card-${p.size}`}
        style={`--accent: ${p.color}; --delay: ${i * 70}ms`}
      >
        <div class="card-cover">
          <span class="card-cover-glow"></span>
          <span class="card-cover-grid"></span>
          <span class="card-monogram">{p.initials}</span>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="card-num">№ {p.n}</span>
            <span class="card-tag">{p.tag}</span>
          </div>
          <h3 class="card-title">{p.name}</h3>
          <p class="card-desc">{p.desc}</p>
          <span class="card-cta">
            <span>View repository</span>
            <span class="card-arrow">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="active">
    <div class="active-head">
      <span class="section-num">§ 01.02</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Helper systems</span>
      <span class="active-count">{HELPERS.length} helpers</span>
    </div>
    <ul class="active-grid">
      {HELPERS.map((p) => (
        <li>
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mini"
            style={`--accent: ${p.color}`}
          >
            <span class="mini-dot"></span>
            <span class="mini-name">{p.name}</span>
            <span class="mini-desc">{p.desc}</span>
            <span class="mini-arrow">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="active">
    <div class="active-head">
      <span class="section-num">§ 01.03</span>
      <span class="section-rule short"></span>
      <span class="section-kw small">Also running</span>
      <span class="active-count">{ACTIVE.length} more</span>
    </div>
    <ul class="active-grid">
      {ACTIVE.map((p) => (
        <li>
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mini"
            style={`--accent: ${p.color}`}
          >
            <span class="mini-dot"></span>
            <span class="mini-name">{p.name}</span>
            <span class="mini-desc">{p.desc}</span>
            <span class="mini-arrow">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
