---
import Layout from '../layouts/Layout.astro';
import BackgroundFX from '../components/BackgroundFX.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import Fleet from '../components/Fleet.astro';
import Spec from '../components/Spec.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

// Foundry landing — composition mirrors the original Next.js page.js:
// BackgroundFX → Nav → Hero → Ticker → Fleet (§01) → Spec (§02) → CTA → FAQ → Footer.
// Each section keeps the same class names so the ported globals.css
// applies unchanged.
---

<Layout>
  <BackgroundFX />
  <Nav />
  <Hero />
  <Ticker />
  <Fleet />
  <Spec />
  <CTA />
  <FAQ />
  <Footer />
</Layout>
