---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { BUILD_LOG } from '../data/build-log';

// Group entries by month for the narrative structure.
const groups: { month: string; entries: typeof BUILD_LOG }[] = [];
for (const entry of BUILD_LOG) {
  const monthKey = entry.date.slice(0, 7); // YYYY-MM
  let group = groups.find((g) => g.month === monthKey);
  if (!group) {
    group = { month: monthKey, entries: [] };
    groups.push(group);
  }
  group.entries.push(entry);
}

const monthLabel = (key: string): string => {
  const [y, m] = key.split('-');
  const months = ['January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];
  return `${months[parseInt(m, 10) - 1]} ${y}`;
};

const totalEntries = BUILD_LOG.length;
const reposTouched = new Set(BUILD_LOG.map((e) => e.repo)).size;
const firstDate = BUILD_LOG[0]?.date ?? '';
const lastDate = BUILD_LOG[BUILD_LOG.length - 1]?.date ?? '';
---

<Layout
  title="Build log — the fleet story · Foundry"
  description="The fleet story as dated entries from real git history. Solo builder + agents, real milestones — not invented narrative."
>
  <Nav />

  <main class="build-log">
    <div class="bl-grid" aria-hidden="true"></div>

    <header class="bl-hero">
      <p class="bl-kicker">
        <span class="bl-led"></span> FLEET BUILD LOG · REAL GIT MILESTONES
      </p>
      <h1>The fleet story</h1>
      <p class="bl-lede">
        Every entry below is anchored to a real commit in a real fleet repository —
        SHA, date, and message from <code>git log</code>. No invented narrative.
        One solo builder, a swarm of agents, and a growing fleet of shipped products
        on Cloudflare's $5 tier.
      </p>
      <div class="bl-stats">
        <div><b>{totalEntries}</b><span>milestones</span></div>
        <div><b>{reposTouched}</b><span>repos</span></div>
        <div><b>{firstDate} → {lastDate}</b><span>span</span></div>
      </div>
    </header>

    <div class="bl-timeline">
      {groups.map((group) => (
        <section class="bl-month">
          <h2 class="bl-month-title">{monthLabel(group.month)}</h2>
          <div class="bl-entries">
            {group.entries.map((entry) => (
              <article class="bl-entry">
                <div class="bl-entry-meta">
                  <time class="bl-date" datetime={entry.date}>{entry.date}</time>
                  <span class="bl-repo">{entry.repo}</span>
                  {entry.sha !== '—' && <span class="bl-sha">{entry.sha}</span>}
                </div>
                <div class="bl-entry-body">
                  <p class="bl-message">{entry.message}</p>
                  <p class="bl-note">{entry.note}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="bl-method">
      <h2>How this log is built</h2>
      <p>
        Each entry is derived from <code>git log --oneline --date=short --format='%h %ad %s'</code>
        run across every fleet repository on 2026-07-17. Commits are curated for
        narrative significance — first commits, major feature ships, deploys, and
        infrastructure milestones. The note field adds context around the real
        commit but does not invent events. The raw git history is the source of truth.
      </p>
    </section>

    <Footer />
  </main>
</Layout>

<style>
  .build-log {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 0 6vw 6rem;
    background: radial-gradient(120% 80% at 50% -10%, #0b1426 0%, #05070d 55%, #03040a 100%);
    color: #dbeafe;
  }
  .bl-grid {
    position: absolute; inset: 0; pointer-events: none; opacity: .25;
    background-image: linear-gradient(#1e3a5f22 1px, transparent 1px), linear-gradient(90deg, #1e3a5f22 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(80% 60% at 50% 30%, #000 30%, transparent 85%);
  }

  .bl-hero { position: relative; text-align: center; padding: 5rem 0 2rem; }
  .bl-kicker {
    display: inline-flex; align-items: center; gap: .5rem;
    font: 600 .72rem/1 ui-monospace, monospace; letter-spacing: .28em;
    color: #67e8f9; text-transform: uppercase;
  }
  .bl-led {
    width: 8px; height: 8px; border-radius: 50%; background: #34d399;
    box-shadow: 0 0 10px #34d399; animation: blink 1.6s ease-in-out infinite;
  }
  @keyframes blink { 50% { opacity: .35; } }
  .bl-hero h1 {
    font: 800 clamp(2.4rem, 6vw, 4.5rem)/1 'Manrope', system-ui, sans-serif;
    margin: .8rem 0 1rem;
    background: linear-gradient(180deg, #fff, #7dd3fc 70%, #38bdf8);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    text-shadow: 0 0 60px #0ea5e955;
  }
  .bl-lede {
    max-width: 62ch; margin: 0 auto; color: #93b4d8; line-height: 1.6; font-size: 1.02rem;
  }
  .bl-lede code { font: 500 .88rem ui-monospace, monospace; color: #5eead4; }
  .bl-stats {
    display: flex; flex-wrap: wrap; gap: 1.2rem; justify-content: center; margin-top: 2.2rem;
  }
  .bl-stats div {
    display: grid; gap: .15rem; padding: .7rem 1.3rem;
    border: 1px solid #1e3a5f; border-radius: 12px; background: #0a132473;
  }
  .bl-stats b { font: 800 1.3rem/1 'Manrope', sans-serif; color: #5eead4; }
  .bl-stats span {
    font: 600 .62rem/1 ui-monospace, monospace; letter-spacing: .14em;
    color: #6b88aa; text-transform: uppercase;
  }

  .bl-timeline { position: relative; max-width: 820px; margin: 3rem auto 0; }
  .bl-timeline::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(180deg, #22d3ee33, #34d39933, transparent);
  }
  .bl-month { position: relative; margin-bottom: 2.5rem; }
  .bl-month-title {
    font: 700 .82rem/1 ui-monospace, monospace; letter-spacing: .22em;
    text-transform: uppercase; color: #5eead4; margin-bottom: 1.2rem;
    padding-left: 1.5rem; position: relative;
  }
  .bl-month-title::before {
    content: ''; position: absolute; left: -5px; top: 50%; transform: translateY(-50%);
    width: 12px; height: 12px; border-radius: 50%; background: #0ea5e9;
    box-shadow: 0 0 12px #0ea5e9;
  }

  .bl-entries { display: grid; gap: 1rem; padding-left: 1.5rem; }
  .bl-entry {
    position: relative; padding: 1.1rem 1.3rem; border-radius: 10px;
    border: 1px solid #173050; background: linear-gradient(180deg, #0b1a2bf2, #081019f2);
    transition: border-color .2s, transform .2s;
  }
  .bl-entry:hover { border-color: #2dd4bf44; transform: translateX(2px); }
  .bl-entry::before {
    content: ''; position: absolute; left: -1.5rem; top: 1.4rem; width: 1rem; height: 1px;
    background: #1e3a5f;
  }
  .bl-entry-meta {
    display: flex; flex-wrap: wrap; gap: .7rem; align-items: center; margin-bottom: .5rem;
  }
  .bl-date {
    font: 600 .72rem ui-monospace, monospace; color: #67e8f9; letter-spacing: .04em;
  }
  .bl-repo {
    font: 600 .66rem ui-monospace, monospace; color: #5eead4;
    padding: .2rem .5rem; border-radius: 5px; background: #0a2230; border: 1px solid #22d3ee33;
  }
  .bl-sha {
    font: 500 .66rem ui-monospace, monospace; color: #6b88aa;
  }
  .bl-message {
    font: 600 .92rem 'Manrope', sans-serif; color: #e0f2fe; margin: 0 0 .4rem;
  }
  .bl-note {
    font-size: .86rem; color: #8fa9c6; line-height: 1.55; margin: 0;
  }

  .bl-method {
    max-width: 760px; margin: 3.5rem auto 0; padding: 1.6rem 1.8rem;
    border-radius: 12px; border: 1px solid #1e3a5f; background: #0a132460;
  }
  .bl-method h2 {
    font: 700 .72rem/1 ui-monospace, monospace; letter-spacing: .22em;
    text-transform: uppercase; color: #5eead4; margin-bottom: .8rem;
  }
  .bl-method p { color: #93b4d8; line-height: 1.65; font-size: .92rem; }
  .bl-method code { font: 500 .82rem ui-monospace, monospace; color: #67e8f9; word-break: break-all; }

  @media (prefers-reduced-motion: reduce) { .bl-led { animation: none; } }
  @media (max-width: 640px) {
    .bl-timeline::before { left: 0; }
    .bl-month-title { padding-left: 1.2rem; }
    .bl-entries { padding-left: 1.2rem; }
  }
</style>
