---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = 'https://sassmaker.com';
const DEFAULT_TITLE = 'Foundry — a personal fleet by Sarthak Agrawal';
const DEFAULT_DESCRIPTION =
  'SaaS Maker is the core product platform, supported by focused repositories for model access, search, media, and performance.';

const { title = DEFAULT_TITLE, description = DEFAULT_DESCRIPTION } = Astro.props;

// Cloudflare Pages serves clean URLs without `.html`; canonicals should match.
const pathname =
  Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '') || '/';
const canonical = new URL(pathname, Astro.site).href;

// Raster OG (social crawlers poorly support SVG). JPG keeps WhatsApp under ~300KB.
const OG_IMAGE = `${SITE_URL}/og-image.jpg`;

const STRUCTURED_DATA = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Foundry',
  alternateName: 'SaaS Maker',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web Browser',
  url: SITE_URL,
  description:
    'The open-source factory floor running underneath every project in the fleet. Registry, feedback, changelog, tasks, audits, widgets — one cockpit, one API, one CLI.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  creator: {
    '@type': 'Person',
    name: 'Sarthak Agrawal',
    url: 'https://sarthakagrawal.dev',
  },
};

const WEBSITE_DATA = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Foundry',
  alternateName: 'SaaS Maker',
  url: 'https://sassmaker.com',
  description:
    'SaaS Maker is the core product platform, supported by focused repositories for model access, search, media, and performance.',
  inLanguage: 'en',
  publisher: {
    '@type': 'Person',
    name: 'Sarthak Agrawal',
    url: 'https://github.com/sarthakagrawal927',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Foundry" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <meta
      name="keywords"
      content="foundry, sarthak agrawal, sassmaker, fleet, indie hacker, open source, portfolio"
    />
    <meta name="author" content="Sarthak Agrawal" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    {/* Non-blocking Google Fonts: media=print → onload='all' keeps the
        font stylesheet off the LCP critical path. The hero h1 paints in
        the system fallback (Manrope falls back to ui-sans-serif), then
        swaps when the woff2 arrives. psi-swarm desktop p75 LCP was
        dominated by a 1.2s render-delay before this change. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      />
    </noscript>

    {/* JSON-LD structured data. The original Next.js layout wrapped this
        in a <template> tag (likely accidental — Google won't read JSON-LD
        from a <template>). Restoring the canonical <script type="…">
        form so crawlers actually pick it up. */}
    <script type="application/ld+json" set:html={JSON.stringify(STRUCTURED_DATA)} />
    <script type="application/ld+json" set:html={JSON.stringify(WEBSITE_DATA)} />
  </head>
  <body>
    <slot />
  </body>
</html>
