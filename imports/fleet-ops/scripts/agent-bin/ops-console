#!/usr/bin/env bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

APP_DIR="/Users/assistant/Desktop/fleet/fleet-ops/apps/ops-console"
SCRIPT_PATH="/Users/assistant/Desktop/fleet/fleet-ops/scripts/agent-bin/ops-console"
LABEL="com.assistant.fleet-ops-console"
HEARTBEAT_LABEL="com.assistant.fleet-ops-console-heartbeat"
LEGACY_REFRESH_LABEL="com.assistant.fleet-ops-console-refresh"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
HEARTBEAT_PLIST="$HOME/Library/LaunchAgents/$HEARTBEAT_LABEL.plist"
LEGACY_REFRESH_PLIST="$HOME/Library/LaunchAgents/$LEGACY_REFRESH_LABEL.plist"
LOG_DIR="$HOME/Library/Logs"
RUNTIME_DIR="$HOME/Library/Application Support/Fleet Ops/ops-console"
HEARTBEAT_RUNNER="$RUNTIME_DIR/heartbeat.zsh"
HEARTBEAT_SCRIPT="$APP_DIR/../../scripts/agent-bin/public-heartbeat.mjs"
PORT="${FLEET_OPS_CONSOLE_PORT:-4329}"
PUBLIC_URL="${FLEET_OPS_CONSOLE_URL:-https://fleet.sassmaker.com}"

usage() {
  cat <<'EOF'
usage: ops-console <install|start|stop|restart|status|open|publish|serve>

Manages the local Fleet Ops Astro console used by the Cloudflare Tunnel.
EOF
}

write_plist() {
  mkdir -p "$HOME/Library/LaunchAgents" "$LOG_DIR" "$RUNTIME_DIR"
  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RUNTIME_DIR/server.mjs</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PORT</key>
    <string>$PORT</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$LOG_DIR/fleet-ops-console.log</string>
  <key>StandardErrorPath</key>
  <string>$LOG_DIR/fleet-ops-console.err.log</string>
  <key>WorkingDirectory</key>
  <string>$RUNTIME_DIR</string>
</dict>
</plist>
EOF
}

write_heartbeat_plist() {
  mkdir -p "$HOME/Library/LaunchAgents" "$LOG_DIR" "$RUNTIME_DIR"
  cat > "$HEARTBEAT_RUNNER" <<EOF
#!/bin/zsh
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\${PATH:-}"
/opt/homebrew/bin/node "$HEARTBEAT_SCRIPT" >/dev/null
EOF
  chmod 755 "$HEARTBEAT_RUNNER"
  cat > "$HEARTBEAT_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$HEARTBEAT_LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>$HEARTBEAT_RUNNER</string>
  </array>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$LOG_DIR/fleet-ops-console-heartbeat.log</string>
  <key>StandardErrorPath</key>
  <string>$LOG_DIR/fleet-ops-console-heartbeat.err.log</string>
  <key>WorkingDirectory</key>
  <string>$APP_DIR</string>
</dict>
</plist>
EOF
}

publish_runtime() {
  cd "$APP_DIR"
  npm run build
  mkdir -p "$RUNTIME_DIR"
  rm -rf "$RUNTIME_DIR/dist"
  cp -R "$APP_DIR/dist" "$RUNTIME_DIR/dist"
  /opt/homebrew/bin/node "$HEARTBEAT_SCRIPT" >/dev/null
  cat > "$RUNTIME_DIR/server.mjs" <<'EOF'
import { createServer } from "node:http";
import { existsSync, readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, join, normalize } from "node:path";

const root = dirname(fileURLToPath(import.meta.url));
const dist = join(root, "dist");
const port = Number(process.env.PORT || 4329);

function htmlFor(pathname) {
  const cleanPath = normalize(decodeURIComponent(pathname)).replace(/^(\.\.[/\\])+/, "");
  const candidates = [
    join(dist, cleanPath, "index.html"),
    join(dist, `${cleanPath}.html`),
    join(dist, "index.html")
  ];
  return candidates.find((candidate) => candidate.startsWith(dist) && existsSync(candidate)) ?? join(dist, "index.html");
}

createServer((request, response) => {
  const url = new URL(request.url || "/", "http://127.0.0.1");
  if (url.pathname === "/healthz") {
    response.writeHead(200, { "content-type": "text/plain; charset=utf-8" });
    response.end("ok");
    return;
  }

  if (url.pathname === "/api/runtime") {
    try {
      const heartbeat = readFileSync(join(root, "runtime.json"), "utf8");
      response.writeHead(200, {
        "content-type": "application/json; charset=utf-8",
        "cache-control": "no-store"
      });
      response.end(heartbeat);
    } catch {
      response.writeHead(503, { "content-type": "application/json; charset=utf-8", "cache-control": "no-store" });
      response.end(JSON.stringify({ error: "heartbeat unavailable" }));
    }
    return;
  }

  try {
    const html = readFileSync(htmlFor(url.pathname), "utf8");
    response.writeHead(200, {
      "content-type": "text/html; charset=utf-8",
      "cache-control": "no-cache"
    });
    response.end(html);
  } catch (error) {
    response.writeHead(503, { "content-type": "text/plain; charset=utf-8", "cache-control": "no-cache" });
    response.end("snapshot unavailable");
  }
}).listen(port, "127.0.0.1", () => {
  console.log(`Fleet Ops Console listening on http://127.0.0.1:${port}`);
});
EOF
}

start_service() {
  publish_runtime
  write_plist
  write_heartbeat_plist
  launchctl bootout "gui/$(id -u)" "$LEGACY_REFRESH_PLIST" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$PLIST"
  launchctl enable "gui/$(id -u)/$LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$(id -u)/$LABEL"
  launchctl bootout "gui/$(id -u)" "$HEARTBEAT_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$HEARTBEAT_PLIST"
  launchctl enable "gui/$(id -u)/$HEARTBEAT_LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$(id -u)/$HEARTBEAT_LABEL"
  "$HEARTBEAT_RUNNER"
}

stop_service() {
  launchctl bootout "gui/$(id -u)" "$PLIST" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$HEARTBEAT_PLIST" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$LEGACY_REFRESH_PLIST" >/dev/null 2>&1 || true
}

case "${1:-}" in
  install|start) start_service ;;
  stop) stop_service ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    launchctl list | grep "$LABEL" || true
    curl -fsS --max-time 5 "http://127.0.0.1:$PORT" >/dev/null && echo "local: ok" || echo "local: down"
    curl -fsS --max-time 5 "http://127.0.0.1:$PORT/projects" >/dev/null && echo "local projects: ok" || echo "local projects: down"
    curl -fsS --max-time 5 "http://127.0.0.1:$PORT/api/runtime" >/dev/null && echo "local heartbeat: ok (60s)" || echo "local heartbeat: down"
    if [ "$(curl -fsSL --max-time 10 "$PUBLIC_URL/healthz" 2>/dev/null || true)" = "ok" ]; then
      echo "public: ok $PUBLIC_URL"
    else
      echo "public: down $PUBLIC_URL"
    fi
    ;;
  open) open "$PUBLIC_URL" ;;
  publish) publish_runtime ;;
  serve)
    publish_runtime
    exec /opt/homebrew/bin/node "$RUNTIME_DIR/server.mjs"
    ;;
  -h|--help|help|"") usage ;;
  *)
    usage >&2
    exit 2
    ;;
esac
