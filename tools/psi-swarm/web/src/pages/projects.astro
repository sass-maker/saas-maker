---
import '../styles/global.css';
import ProjectsView from '../components/ProjectsView.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>psi-swarm · projects</title>
  </head>
  <body class="min-h-screen">
    <main class="max-w-5xl mx-auto px-6 py-10">
      <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight">
          <span class="text-[var(--color-cyan)]">psi</span>-swarm · projects
        </h1>
        <p class="text-[var(--color-dim)] mt-1 text-sm">
          Tracked URLs from your local SQLite history. Latest performance, recent trend, click to drill into the full run history.
        </p>
        <p class="text-[var(--color-dim)] mt-3 text-xs flex flex-wrap gap-4">
          <a href="./" class="text-[var(--color-cyan)] hover:underline">← single-URL dashboard</a>
          <a href="./compare/" class="hover:text-[var(--color-text)]">compare</a>
          <a href="./watchlist/" class="hover:text-[var(--color-text)]">watchlist</a>
          <a href="./gallery/" class="hover:text-[var(--color-text)]">demo gallery</a>
        </p>
      </header>
      <ProjectsView client:load />
    </main>
  </body>
</html>
