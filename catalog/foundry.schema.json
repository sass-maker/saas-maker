{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sassmaker.com/schemas/foundry.schema.json",
  "title": "Canonical Foundry catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "updatedAt",
    "sourcePolicy",
    "defaults",
    "distributionPolicy",
    "performancePolicy",
    "performanceSurfaces",
    "owners",
    "attention",
    "automationDetails",
    "pillars",
    "products",
    "components",
    "packages",
    "skills",
    "repositories",
    "automations",
    "publicRecords"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "updatedAt": { "type": "string", "format": "date" },
    "sourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical", "generatedDirectory", "evidenceStates"],
      "properties": {
        "canonical": { "const": "catalog/foundry.json" },
        "generatedDirectory": { "const": "catalog/generated" },
        "evidenceStates": {
          "type": "array",
          "prefixItems": [
            { "const": "configured" },
            { "const": "verified" },
            { "const": "stale" },
            { "const": "unknown" },
            { "const": "not-applicable" }
          ],
          "items": false
        }
      }
    },
    "defaults": { "type": "object" },
    "distributionPolicy": { "$ref": "#/$defs/distributionPolicy" },
    "performancePolicy": { "$ref": "#/$defs/performancePolicy" },
    "performanceSurfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/performanceSurface" }
    },
    "owners": { "type": "array", "items": { "$ref": "#/$defs/owner" } },
    "attention": { "type": "array", "items": { "$ref": "#/$defs/namedId" } },
    "automationDetails": { "type": "array", "items": { "$ref": "#/$defs/automationDetail" } },
    "pillars": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "$ref": "#/$defs/pillar" } },
    "products": { "type": "array", "items": { "$ref": "#/$defs/product" } },
    "components": { "type": "array", "items": { "$ref": "#/$defs/component" } },
    "packages": { "type": "array", "items": { "$ref": "#/$defs/package" } },
    "skills": { "type": "array", "items": { "$ref": "#/$defs/skill" } },
    "repositories": { "type": "array", "items": { "$ref": "#/$defs/repository" } },
    "automations": { "type": "array", "items": { "$ref": "#/$defs/automation" } },
    "publicRecords": { "type": "array", "items": { "$ref": "#/$defs/publicRecord" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$" },
    "state": {
      "enum": ["configured", "verified", "stale", "unknown", "not-applicable"]
    },
    "namedId": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["person", "system", "unowned"] }
      }
    },
    "pillar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "ownerId", "contracts", "evidenceSources"],
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "ownerId": { "$ref": "#/$defs/id" },
        "contracts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "evidenceSources": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "distributionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "state", "ownerId", "contentFactory", "externalServices", "evidence"],
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "state": { "$ref": "#/$defs/state" },
        "ownerId": { "$ref": "#/$defs/id" },
        "contentFactory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "path", "sourceProductId", "publishesExternally", "allowedCapabilities"],
          "properties": {
            "id": { "const": "content-factory" },
            "path": { "const": "services/content-factory" },
            "sourceProductId": { "$ref": "#/$defs/id" },
            "publishesExternally": { "const": false },
            "allowedCapabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
          }
        },
        "externalServices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "ownerId", "source", "deployment", "versionPolicy", "state"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "kind": { "type": "string" },
              "ownerId": { "$ref": "#/$defs/id" },
              "source": { "type": "string", "format": "uri" },
              "deployment": { "type": "string" },
              "versionPolicy": { "type": "string" },
              "state": { "$ref": "#/$defs/state" }
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["freshnessHours", "states", "allowlist", "excludedDataClasses"],
          "properties": {
            "freshnessHours": { "type": "integer", "minimum": 1, "maximum": 720 },
            "states": { "type": "array", "minItems": 4, "uniqueItems": true, "items": { "enum": ["fresh", "stale", "failed", "unmeasured"] } },
            "allowlist": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
            "excludedDataClasses": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
          }
        }
      }
    },
    "performancePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "mode", "observationDays", "retention", "sampling", "synthetic", "privacy"],
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "mode": { "enum": ["observation", "alerting", "enforcing"] },
        "observationDays": { "type": "integer", "minimum": 14 },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spanDays", "rollupMonths"],
          "properties": {
            "spanDays": { "type": "integer", "minimum": 1, "maximum": 30 },
            "rollupMonths": { "type": "integer", "minimum": 1, "maximum": 24 }
          }
        },
        "sampling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["successRate", "errorsRate", "slowRate", "perRoutePerMinuteCap"],
          "properties": {
            "successRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "errorsRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "slowRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "perRoutePerMinuteCap": { "type": "integer", "minimum": 1, "maximum": 1000 }
          }
        },
        "synthetic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["api", "web", "schedulesActive"],
          "properties": {
            "api": {
              "type": "object",
              "additionalProperties": false,
              "required": ["coldSamples", "warmSamples", "cadence"],
              "properties": {
                "coldSamples": { "type": "integer", "minimum": 1, "maximum": 20 },
                "warmSamples": { "type": "integer", "minimum": 1, "maximum": 100 },
                "cadence": { "const": "daily" }
              }
            },
            "web": {
              "type": "object",
              "additionalProperties": false,
              "required": ["desktopSamples", "mobileSamples", "cadence"],
              "properties": {
                "desktopSamples": { "type": "integer", "minimum": 1, "maximum": 20 },
                "mobileSamples": { "type": "integer", "minimum": 1, "maximum": 20 },
                "cadence": { "const": "weekly" }
              }
            },
            "schedulesActive": { "const": false }
          }
        },
        "privacy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rawQueries", "queryValues", "payloadBodies", "authorization", "userIdentity"],
          "properties": {
            "rawQueries": { "const": false },
            "queryValues": { "const": false },
            "payloadBodies": { "const": false },
            "authorization": { "const": false },
            "userIdentity": { "const": false }
          }
        }
      }
    },
    "performanceSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "projectId", "name", "kind", "url", "method", "expectedStatuses", "timeoutMs", "criticality", "freshnessHours", "budget"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "projectId": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["web", "api"] },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "method": { "enum": ["GET", "HEAD"] },
        "expectedStatuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 200, "maximum": 399 }
        },
        "timeoutMs": { "type": "integer", "minimum": 250, "maximum": 30000 },
        "criticality": { "enum": ["critical", "standard", "low"] },
        "freshnessHours": { "type": "integer", "minimum": 1, "maximum": 720 },
        "budget": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["metric", "percentile", "limitMs", "mode", "approvedAt"],
              "properties": {
                "metric": { "enum": ["lcp", "total", "ttfb"] },
                "percentile": { "enum": ["p50", "p75", "p90", "p95", "p99"] },
                "limitMs": { "type": "integer", "minimum": 1 },
                "mode": { "enum": ["alerting", "enforcing"] },
                "approvedAt": { "type": "string", "format": "date-time" }
              }
            }
          ]
        }
      }
    },
    "automationDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["productId", "surfaces", "dependencies"],
      "properties": {
        "productId": { "$ref": "#/$defs/id" },
        "surfaces": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "family", "lifecycle", "attention", "ownerId", "repositoryId", "runtimes", "pillarIds", "actionPolicy", "alertPolicy", "exceptions"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "lifecycle": { "enum": ["maintained", "frozen", "retired", "removed"] },
        "attention": { "enum": ["my-work", "toolbox", "foundry", "ignored", "removed"] },
        "ownerId": { "$ref": "#/$defs/id" },
        "repositoryId": { "type": ["string", "null"] },
        "runtimes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "pillarIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "observability": { "$ref": "#/$defs/observability" },
        "actionPolicy": { "type": "string" },
        "alertPolicy": { "type": "string" },
        "exceptions": { "type": "array", "items": { "type": "object" } }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "productId", "family", "tier", "repositoryId", "deployment", "inPublicRegistry", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "productId": { "$ref": "#/$defs/id" },
        "family": { "type": "string" },
        "tier": { "type": "string" },
        "repositoryId": { "type": ["string", "null"] },
        "app": { "type": "string" },
        "inPublicRegistry": { "type": "boolean" },
        "notes": { "type": "string" },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "target", "domains", "state", "sourceStatus", "verification"],
          "properties": {
            "kind": { "type": "string" },
            "target": { "type": ["string", "null"] },
            "domains": { "type": "array", "items": { "type": "string", "format": "hostname" }, "uniqueItems": true },
            "state": { "$ref": "#/$defs/state" },
            "sourceStatus": { "type": "string" },
            "verification": {
              "type": "object",
              "additionalProperties": false,
              "required": ["state", "source", "observedAt"],
              "properties": {
                "state": { "$ref": "#/$defs/state" },
                "source": { "type": "string" },
                "observedAt": { "type": ["string", "null"], "format": "date" }
              }
            }
          }
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "version", "private", "state"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "version": { "type": "string" },
        "private": { "type": "boolean" },
        "description": { "type": ["string", "null"] },
        "bin": { "type": ["object", "null"] },
        "state": { "$ref": "#/$defs/state" }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "description", "state"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "remote", "state"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "type": ["string", "null"] },
        "remote": { "type": ["string", "null"] },
        "state": { "$ref": "#/$defs/state" }
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "ownerId", "evidenceOwnerId", "state", "schedule"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "ownerId": { "$ref": "#/$defs/id" },
        "evidenceOwnerId": { "$ref": "#/$defs/id" },
        "state": { "$ref": "#/$defs/state" },
        "schedule": {
          "type": ["object", "null"],
          "properties": {
            "ownerId": { "type": "string", "minLength": 1 },
            "expression": { "type": "string", "minLength": 1 },
            "format": { "enum": ["cron", "rrule"] }
          },
          "required": ["ownerId", "expression", "format"],
          "additionalProperties": false
        }
      }
    },
    "publicRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "legacyKey", "name", "description", "url", "tier", "category", "priority", "maturity"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "legacyKey": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "path": { "type": "string" },
        "tier": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "spotlight": { "type": "boolean" },
        "maturity": { "type": "string" }
      }
    }
  }
}
