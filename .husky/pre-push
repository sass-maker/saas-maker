#!/bin/sh
set -e

echo "🛡️  Foundry pre-push gate"

# 1. Lint (fast — Biome or ESLint, whatever is configured)
if grep -q '"lint"' package.json 2>/dev/null; then
  echo "→ lint"
  pnpm run lint --if-present || { echo "lint failed — fix before pushing" >&2; exit 1; }
fi

# 2. Tests — block push when broken
echo "→ test"
pnpm test || { echo "tests failed — push aborted" >&2; exit 1; }

# 3. API dry-run build — catch broken Hono routes / missing imports
echo "→ api dry-run"
pnpm -F @saas-maker/api exec wrangler deploy --dry-run --outdir /tmp/foundry-dry >/dev/null 2>&1 \
  || { echo "API build failed — push aborted" >&2; exit 1; }

# 4. CLI build — catch broken commands / typescript errors
echo "→ cli build"
pnpm -F @saas-maker/cli build >/dev/null 2>&1 \
  || { echo "CLI build failed — push aborted" >&2; exit 1; }

# 5. Secret scan — abort if tokens/keys found in tracked files
echo "→ secret scan"
SECRETS=$(git ls-files -z 2>/dev/null \
  | xargs -0 grep -lE \
    'sk-(proj-|ant-)?[A-Za-z0-9_-]{20,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]{36}|AIzaSy[A-Za-z0-9_-]{33}|xoxb-[A-Za-z0-9-]+|-----BEGIN (RSA |EC )?PRIVATE KEY-----' 2>/dev/null \
  | grep -vE '(\.example$|\.sample$|/tests?/|/__tests__/|/fixtures?/|/mocks?/|/vendor/)' \
  || true)
if [ -n "$SECRETS" ]; then
  echo "Possible secret(s) in tracked files — push aborted:" >&2
  printf '  %s\n' $SECRETS >&2
  exit 1
fi

echo "✓ all gates passed"
